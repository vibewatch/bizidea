---
interface Props {
  size?: 'hero' | 'block' | 'feature';
  as?: 'h1' | 'h2' | 'h3';
  href?: string;
  class?: string;
}
const { size = 'block', as: Tag = 'h2', href, class: cls = '' } = Astro.props as Props;
---
<Tag class:list={['bz-headline', `bz-headline--${size}`, cls]}>
  {href ? <a href={href}><slot /></a> : <slot />}
</Tag>
<style>
  .bz-headline {
    font-family: var(--font-display);
    color: var(--ink-strong);
    font-weight: 700;
    margin: 0;
    text-wrap: balance;
  }
  .bz-headline--hero {
    font-size: var(--fs-3xl);
    line-height: var(--lh-display-hero);
    letter-spacing: var(--tracking-display-tight);
    font-weight: 800;
    max-width: 28ch;
  }
  .bz-headline--feature {
    font-size: var(--fs-2xl);
    line-height: var(--lh-display-block);
    letter-spacing: var(--tracking-display-tight);
    font-weight: 800;
    max-width: 26ch;
  }
  .bz-headline--block {
    font-size: var(--fs-xl);
    line-height: var(--lh-display-block);
    letter-spacing: var(--tracking-display-snug);
  }
  .bz-headline a {
    color: inherit;
    text-decoration: none;
  }
  .bz-headline a:hover,
  .bz-headline a:focus-visible {
    color: var(--claret);
    text-decoration: underline;
    text-decoration-thickness: 2px;
    text-underline-offset: 4px;
    text-decoration-color: rgba(153, 15, 61, 0.5);
  }
</style>
