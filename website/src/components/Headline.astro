---
interface Props {
  size?: 'hero' | 'block' | 'feature';
  as?: 'h1' | 'h2' | 'h3';
  href?: string;
  class?: string;
}
const { size = 'block', as: Tag = 'h2', href, class: cls = '' } = Astro.props as Props;
---
<Tag class:list={['bz-headline', `bz-headline--${size}`, cls]}>
  {href ? <a href={href}><slot /></a> : <slot />}
</Tag>
<style>
  .bz-headline {
    font-family: var(--font-display);
    color: var(--ink-page);
    font-weight: 400;
    margin: 0;
  }
  .bz-headline--hero {
    font-size: clamp(2.25rem, 5.5vw, 4rem);
    line-height: var(--lh-display-hero);
    letter-spacing: -0.5px;
  }
  .bz-headline--feature {
    font-size: clamp(1.75rem, 3.5vw, 2.5rem);
    line-height: var(--lh-display-block);
    letter-spacing: -0.3px;
  }
  .bz-headline--block {
    font-size: 1.625rem;
    line-height: var(--lh-display-block);
    letter-spacing: -0.144px;
  }
  .bz-headline a {
    color: inherit;
    text-decoration: none;
  }
  .bz-headline a:hover,
  .bz-headline a:focus-visible {
    color: var(--link-blue);
    text-decoration: underline;
    text-underline-offset: 3px;
  }
</style>
