---
import Kicker from './Kicker.astro';
import Headline from './Headline.astro';
import RatingSparkline from './RatingSparkline.astro';
import type { Lang } from '../lib/i18n';

interface Props {
  href: string;
  kicker: string;
  headline: string;
  deck?: string;
  meta?: string;
  size?: 'block' | 'feature';
  rating?: { overall: number; dimensions: any };
  lang?: Lang;
}
const { href, kicker, headline, deck, meta, size = 'block', rating, lang = 'en' } = Astro.props as Props;
const tier = !rating ? 'na'
  : rating.overall >= 3.8 ? 'hi'
  : rating.overall >= 2.8 ? 'mid'
  : 'lo';
---
<article class:list={['bz-tile', `bz-tile--${size}`, `bz-tile--${tier}`]}>
  <Kicker bold={size === 'feature'}>{kicker}</Kicker>
  <Headline class="bz-tile__headline" size={size === 'feature' ? 'feature' : 'block'} href={href}>{headline}</Headline>
  {deck && <p class="bz-tile__deck">{deck}</p>}
  <div class="bz-tile__foot">
    {rating && (
      <RatingSparkline dimensions={rating.dimensions} overall={rating.overall} size="sm" lang={lang} />
    )}
    {meta && <p class="bz-tile__meta bz-label">{meta}</p>}
  </div>
</article>
<style>
  .bz-tile {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    padding: var(--space-4) var(--space-4) var(--space-5);
    border-left: 3px solid transparent;
    transition: border-left-color 160ms ease, background 160ms ease, transform 160ms ease;
  }
  .bz-tile:hover {
    background: rgba(242, 223, 206, 0.4);
    transform: translateX(2px);
  }
  .bz-tile--hi { border-left-color: var(--ink-strong); }
  .bz-tile--mid { border-left-color: var(--wheat-300); }
  .bz-tile--lo { border-left-color: var(--claret); }
  .bz-tile--na { border-left-color: var(--hairline); }
  .bz-tile--feature { padding: var(--space-5) var(--space-4) var(--space-6); border-left-width: 4px; }
  .bz-tile :global(.bz-kicker) {
    font-size: var(--fs-sm);
    line-height: 1.25;
    letter-spacing: 0.05em;
  }
  .bz-tile :global(.bz-tile__headline) {
    font-size: clamp(1.375rem, 0.55vw + 1.15rem, 1.625rem);
    line-height: 1.18;
    letter-spacing: var(--tracking-display-snug);
    font-weight: 700;
    color: var(--ink-strong);
  }
  .bz-tile--feature :global(.bz-tile__headline) {
    font-size: clamp(1.875rem, 1.25vw + 1.25rem, 2.5rem);
    line-height: var(--lh-display-block);
    font-weight: 800;
  }
  .bz-tile__deck {
    font-family: var(--font-sans);
    font-size: var(--fs-base);
    line-height: 1.5;
    color: var(--caption-gray);
    margin: 0;
    text-wrap: pretty;
  }
  .bz-tile__foot {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-3);
    flex-wrap: wrap;
    margin-top: auto;
    padding-top: var(--space-2);
  }
  .bz-tile__meta {
    color: var(--caption-gray);
    font-size: var(--fs-sm);
    margin: 0;
  }
</style>
