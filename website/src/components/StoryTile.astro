---
import Kicker from './Kicker.astro';
import Headline from './Headline.astro';

interface Props {
  href: string;
  kicker: string;
  headline: string;
  deck?: string;
  meta?: string;
  size?: 'block' | 'feature';
}
const { href, kicker, headline, deck, meta, size = 'block' } = Astro.props as Props;
---
<article class:list={['bz-tile', `bz-tile--${size}`]}>
  <Kicker bold={size === 'feature'}>{kicker}</Kicker>
  <Headline size={size === 'feature' ? 'feature' : 'block'} href={href}>{headline}</Headline>
  {deck && <p class="bz-tile__deck">{deck}</p>}
  {meta && <p class="bz-tile__meta bz-mono">{meta}</p>}
</article>
<style>
  .bz-tile {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    padding: var(--space-4) 0;
  }
  .bz-tile--feature { padding: var(--space-5) 0 var(--space-6); }
  .bz-tile__deck {
    font-family: var(--font-sans);
    font-size: var(--fs-base);
    line-height: 1.45;
    color: var(--ink-page);
    margin: 0;
  }
  .bz-tile__meta {
    color: var(--caption-gray);
    margin: 0;
  }
</style>
