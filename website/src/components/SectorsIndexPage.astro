---
import BaseLayout from '../layouts/BaseLayout.astro';
import Ribbon from './Ribbon.astro';
import Rule from './Rule.astro';
import { t, type Lang } from '../lib/i18n';
import { languagePrefix, type IdeaEntry } from '../lib/page-helpers';
import { formatMonthLabel, monthSlugForTimestamp, summarizeReportEntries } from '../lib/reports';

interface SectorGroup {
  slug: string;
  label: string;
  entries: IdeaEntry[];
}

interface Props {
  sectorGroups: SectorGroup[];
  lang: Lang;
  langSwitchHref: string;
}

const { sectorGroups, lang, langSwitchHref } = Astro.props as Props;
const base = import.meta.env.BASE_URL;
const sectorPrefix = `${languagePrefix(base, lang)}sectors/`;
---

<BaseLayout
  title={t('sectors.title', lang)}
  description={t('sectors.description', lang)}
  lang={lang}
  langSwitchHref={langSwitchHref}
>
  <section class="bz-page-masthead">
    <div class="bz-container">
      <p class="bz-page-masthead__eyebrow bz-label">
        {sectorGroups.length} {t('sectors.ribbon', lang).toLowerCase()}
      </p>
      <h1 class="bz-page-masthead__title">{t('sectors.heading', lang)}</h1>
      <p class="bz-page-masthead__deck">{t('sectors.deck', lang)}</p>
    </div>
  </section>

  <Rule weight="thin" />
  <Ribbon label={t('sectors.ribbon', lang)} id="sector-index" />

  <div class="bz-container">
    <div class="bz-sector-grid">
      {sectorGroups.map((group) => {
        const summary = summarizeReportEntries(group.entries, lang);
        const recentMonth = formatMonthLabel(monthSlugForTimestamp(group.entries[0]?.data.runTimestamp ?? ''), lang);
        return (
          <a class="bz-sector-card" href={`${sectorPrefix}${group.slug}/`}>
            <span class="bz-sector-card__label">{group.label}</span>
            <span class="bz-sector-card__count bz-label">
              {group.entries.length} {group.entries.length === 1 ? t('home.dossierCount.one', lang) : t('home.dossierCount.other', lang)}
            </span>
            <span class="bz-sector-card__meta bz-label">
              {t('archive.summary.avgRating', lang)} {summary.averageRating?.toFixed(1) ?? '—'} · {t('sectors.months', lang)} {recentMonth}
            </span>
            <span class="bz-sector-card__cta bz-label">
              {t('sectors.open', lang)}
              <svg class="bz-card-arrow" viewBox="0 0 16 16" aria-hidden="true" focusable="false">
                <path d="M3 8h9M8.5 4l4 4-4 4" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </span>
          </a>
        );
      })}
    </div>
  </div>
</BaseLayout>

<style>
  .bz-sector-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-4) var(--space-6);
  }
  .bz-sector-card {
    display: flex;
    flex-direction: column;
    min-height: 184px;
    gap: var(--space-2);
    background:
      linear-gradient(135deg, rgba(13, 118, 128, 0.08), transparent 46%),
      rgba(242, 223, 206, 0.55);
    border-top: 3px solid var(--claret);
    border-left: 3px solid transparent;
    color: var(--ink-page);
    text-decoration: none;
    padding: var(--space-4);
    transition: background 120ms ease, border-left-color 120ms ease, transform 120ms ease;
  }
  .bz-sector-card:hover {
    background:
      linear-gradient(135deg, rgba(13, 118, 128, 0.12), transparent 48%),
      var(--paper-wheat);
    border-left-color: var(--claret);
    transform: translateY(-2px);
  }
  .bz-sector-card__label {
    font-family: var(--font-display);
    font-size: clamp(1.875rem, 1vw + 1.1rem, 2.25rem);
    font-weight: 700;
    line-height: 1.08;
    letter-spacing: var(--tracking-display-snug);
  }
  .bz-sector-card__count {
    color: var(--caption-gray);
    border-top: var(--rule-hairline);
    margin-top: var(--space-2);
    padding-top: var(--space-3);
  }
  .bz-sector-card__count { font-size: var(--fs-base); }
  .bz-sector-card__meta { color: var(--caption-gray); font-size: var(--fs-base); }
  .bz-sector-card__cta {
    align-self: flex-start;
    color: var(--claret);
    margin-top: auto;
    padding-bottom: var(--space-1);
    font-size: var(--fs-base);
    display: inline-flex;
    align-items: center;
    gap: var(--space-1);
  }
  .bz-card-arrow {
    width: 0.9em;
    height: 0.9em;
    opacity: 0;
    transform: translateX(-0.25em);
    transition: opacity 180ms ease, transform 220ms ease;
  }
  .bz-sector-card:hover .bz-card-arrow,
  .bz-sector-card:focus-visible .bz-card-arrow {
    opacity: 1;
    transform: translateX(0);
  }
  @media (prefers-reduced-motion: reduce) {
    .bz-card-arrow { transition: none; }
  }
  @media (max-width: 1023px) { .bz-sector-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 599px) { .bz-sector-grid { grid-template-columns: 1fr; } }
</style>
