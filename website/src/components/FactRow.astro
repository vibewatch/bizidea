---
interface Row { label: string; value: string | null; sub?: string; subHtml?: string }
interface Props {
  caption?: string;
  rows: Row[];
}
const { caption, rows } = Astro.props as Props;
---
<table class="bz-fact">
  {caption && <caption class="bz-mono bz-fact__caption">{caption}</caption>}
  <tbody>
    {rows.map((r) => (
      <tr>
        <th scope="row" class="bz-mono bz-fact__th">{r.label}</th>
        <td class="bz-fact__td">
          <span class="bz-fact__value">{r.value ?? '—'}</span>
          {r.subHtml
            ? <span class="bz-fact__sub" set:html={r.subHtml}></span>
            : r.sub && <span class="bz-fact__sub">{r.sub}</span>}
        </td>
      </tr>
    ))}
  </tbody>
</table>
<style>
  .bz-fact {
    width: 100%;
    border-collapse: collapse;
    margin: var(--space-3) 0 var(--space-5);
    border-top: var(--rule-thin);
    border-bottom: var(--rule-thin);
  }
  .bz-fact__caption {
    text-align: left;
    color: var(--caption-gray);
    padding-bottom: var(--space-2);
    caption-side: top;
  }
  .bz-fact__th {
    text-align: left;
    color: var(--caption-gray);
    padding: var(--space-3) var(--space-4) var(--space-3) 0;
    border-top: var(--rule-hairline);
    font-weight: 400;
    width: 30%;
    vertical-align: top;
  }
  .bz-fact__td {
    padding: var(--space-3) 0;
    border-top: var(--rule-hairline);
    vertical-align: top;
  }
  .bz-fact tr:first-child .bz-fact__th,
  .bz-fact tr:first-child .bz-fact__td { border-top: 0; }
  .bz-fact__value {
    font-family: var(--font-serif);
    font-size: 1.0625rem;
    line-height: 1.45;
    color: var(--ink-page);
    display: block;
  }
  .bz-fact__sub {
    font-family: var(--font-mono);
    text-transform: uppercase;
    letter-spacing: 0.92px;
    font-size: 0.75rem;
    color: var(--caption-gray);
    display: block;
    margin-top: var(--space-1);
  }
</style>
