---
interface Row { label: string; value: string | null; sub?: string; subHtml?: string }
interface Props {
  caption?: string;
  rows: Row[];
}
const { caption, rows } = Astro.props as Props;
---
<table class="bz-fact">
  {caption && <caption class="bz-label bz-fact__caption">{caption}</caption>}
  <tbody>
    {rows.map((r) => (
      <tr>
        <th scope="row" class="bz-label bz-fact__th">{r.label}</th>
        <td class="bz-fact__td">
          <span class="bz-fact__value">{r.value ?? '—'}</span>
          {r.subHtml
            ? <span class="bz-fact__sub" set:html={r.subHtml}></span>
            : r.sub && <span class="bz-fact__sub">{r.sub}</span>}
        </td>
      </tr>
    ))}
  </tbody>
</table>
<style>
  .bz-fact {
    width: 100%;
    border-collapse: separate;
    border-spacing: 0;
    margin: var(--space-3) 0 var(--space-5);
    background: var(--paper-soft);
    border: 1px solid var(--hairline);
    border-top: 2px solid var(--claret);
    font-family: var(--font-sans);
    font-size: 0.9375rem;
    line-height: 1.5;
  }
  .bz-fact__caption {
    text-align: left;
    color: var(--caption-gray);
    padding-bottom: var(--space-2);
    caption-side: top;
  }
  .bz-fact__th {
    text-align: left;
    color: var(--claret);
    background: rgba(242, 223, 206, 0.45);
    padding: var(--space-3) var(--space-4);
    border-top: var(--rule-hairline);
    border-right: 1px solid var(--hairline);
    font-weight: 700;
    letter-spacing: 0.04em;
    width: 30%;
    vertical-align: top;
  }
  .bz-fact__td {
    padding: var(--space-3) var(--space-4);
    border-top: var(--rule-hairline);
    vertical-align: top;
  }
  .bz-fact tr:nth-child(even) .bz-fact__td { background-color: rgba(242, 223, 206, 0.16); }
  .bz-fact tr:first-child .bz-fact__th,
  .bz-fact tr:first-child .bz-fact__td { border-top: 0; }
  .bz-fact__value {
    font-family: inherit;
    font-size: inherit;
    line-height: inherit;
    color: var(--ink-strong);
    font-weight: 600;
    display: block;
  }
  .bz-fact__sub {
    font-family: inherit;
    font-size: var(--fs-sm);
    line-height: 1.5;
    color: var(--caption-gray);
    display: block;
    margin-top: var(--space-1);
  }
</style>
