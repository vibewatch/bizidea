---
import Ribbon from './Ribbon.astro';
import Rule from './Rule.astro';
import { t, type Lang } from '../lib/i18n';

interface Props {
  indexUrl: string;
  lang: Lang;
}

const { indexUrl, lang } = Astro.props;
---
<section class="bz-page-masthead">
  <div class="bz-container">
    <p class="bz-page-masthead__eyebrow bz-label">{t('footer.search', lang)}</p>
    <h1 class="bz-page-masthead__title">{t('search.heading', lang)}</h1>
    <p class="bz-page-masthead__deck">{t('search.deck', lang)}</p>
  </div>
</section>

<Rule weight="thin" />
<Ribbon label={t('search.ribbon', lang)} id="search-results" />

<div
  class="bz-container bz-search"
  data-search-root
  data-index-url={indexUrl}
  data-help={t('search.help', lang)}
  data-empty={t('search.noResults', lang)}
  data-count-label={t('search.count', lang)}
>
  <label class="bz-search__label bz-label" for="bizidea-search">{t('footer.search', lang)}</label>
  <input
    id="bizidea-search"
    class="bz-search__input"
    type="search"
    placeholder={t('search.placeholder', lang)}
    autocomplete="off"
    data-search-input
  />
  <p class="bz-search__status bz-label" data-search-status>{t('search.help', lang)}</p>
  <div class="bz-search__results" data-search-results></div>
</div>

<script>
  const root = document.querySelector('[data-search-root]');
  const input = root?.querySelector('[data-search-input]');
  const status = root?.querySelector('[data-search-status]');
  const results = root?.querySelector('[data-search-results]');
  const state = { docs: [] };

  const normalize = (value) => String(value ?? '').trim().toLowerCase();
  const scoreFor = (doc, terms) => terms.reduce((score, term) => {
    if (normalize(doc.title).includes(term)) return score + 6;
    if (normalize(doc.kicker).includes(term)) return score + 4;
    if (normalize(doc.sectorLabel).includes(term) || normalize(doc.sector).includes(term)) return score + 3;
    if (doc.searchText.includes(term)) return score + 1;
    return score;
  }, doc.rating / 10);

  const clearResults = (message) => {
    if (!status || !results) return;
    status.textContent = message;
    results.replaceChildren();
  };

  const render = () => {
    if (!root || !input || !status || !results) return;
    const query = normalize(input.value);
    if (!query) {
      clearResults(root.dataset.help || '');
      return;
    }
    const terms = query.split(/\s+/).filter(Boolean);
    const matches = state.docs
      .filter((doc) => terms.every((term) => doc.searchText.includes(term)))
      .map((doc) => ({ doc, score: scoreFor(doc, terms) }))
      .sort((a, b) => b.score - a.score || b.doc.runTimestamp.localeCompare(a.doc.runTimestamp))
      .slice(0, 30)
      .map(({ doc }) => doc);

    status.textContent = matches.length
      ? `${matches.length} ${root.dataset.countLabel || 'results'}`.trim()
      : (root.dataset.empty || 'No results');
    results.replaceChildren(...matches.map((doc) => {
      const link = document.createElement('a');
      link.className = 'bz-search-card';
      link.href = doc.href;

      const kicker = document.createElement('span');
      kicker.className = 'bz-search-card__kicker bz-label';
      kicker.textContent = `${doc.kicker} · ${doc.sectorLabel} · ${doc.rating.toFixed(1)}`;

      const title = document.createElement('span');
      title.className = 'bz-search-card__title';
      title.textContent = doc.title;

      const topic = document.createElement('span');
      topic.className = 'bz-search-card__topic';
      topic.textContent = doc.topic;

      link.append(kicker, title, topic);
      return link;
    }));
  };

  if (root && input) {
    fetch(root.dataset.indexUrl || '')
      .then((response) => response.json())
      .then((docs) => { state.docs = Array.isArray(docs) ? docs : []; render(); })
      .catch(() => clearResults(root.dataset.empty || 'No results'));
    input.addEventListener('input', render);
  }
</script>

<style>
  .bz-search { display: flex; flex-direction: column; gap: var(--space-3); }
  .bz-search__label { color: var(--caption-gray); }
  .bz-search__input {
    width: 100%;
    border: var(--rule-thin);
    background: var(--paper);
    color: var(--ink-page);
    font-family: var(--font-display);
    font-size: var(--fs-xl);
    font-weight: 700;
    line-height: 1.2;
    padding: var(--space-3) var(--space-4);
  }
  .bz-search__input:focus { outline: 3px solid rgba(153, 15, 61, 0.18); border-color: var(--claret); }
  .bz-search__status { color: var(--caption-gray); margin: 0; }
  .bz-search__results { display: grid; grid-template-columns: 1fr; gap: 0; }
  :global(.bz-search-card) {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    color: var(--ink-page);
    text-decoration: none;
    border-top: var(--rule-thin);
    border-left: 3px solid transparent;
    padding: var(--space-4) 0 var(--space-4) var(--space-4);
  }
  :global(.bz-search-card:hover) { background: rgba(242, 223, 206, 0.35); border-left-color: var(--claret); }
  :global(.bz-search-card__kicker) { color: var(--caption-gray); font-size: var(--fs-base); }
  :global(.bz-search-card__title) {
    font-family: var(--font-display);
    font-size: clamp(1.5rem, 0.55vw + 1.25rem, 1.875rem);
    font-weight: 700;
    line-height: 1.14;
    letter-spacing: var(--tracking-display-snug);
  }
  :global(.bz-search-card__topic) {
    font-family: var(--font-sans);
    font-size: var(--fs-base);
    line-height: 1.45;
  }
</style>
