---
interface Props {
  weight?: 'hairline' | 'thin' | 'hard';
  class?: string;
}
const { weight = 'hairline', class: cls = '' } = Astro.props as Props;
---
<hr class:list={['bz-rule', `bz-rule--${weight}`, cls]} />
<style>
  .bz-rule { margin: var(--space-5) 0; border: 0; }
  .bz-rule--hairline { border-top: var(--rule-hairline); }
  .bz-rule--thin { border-top: var(--rule-thin); }
  .bz-rule--hard { border-top: var(--rule-hard); }
</style>
