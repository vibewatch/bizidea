---
// Business Model Canvas (Osterwalder) — 9 blocks in canonical layout.
// Top row: KP | KA + KR | VP | CR + CH | CS
// Bottom row: Cost structure | Revenue streams
import { t, type Lang } from '../lib/i18n';
interface Props {
  canvas: any;
  lang?: Lang;
}
const { canvas, lang = 'en' } = Astro.props as Props;

const fmt = (v: any): string[] => {
  if (!v) return [];
  if (Array.isArray(v)) return v.map(String);
  return [String(v)];
};

const blocks = {
  keyPartners: fmt(canvas?.keyPartners),
  keyActivities: fmt(canvas?.keyActivities),
  keyResources: fmt(canvas?.keyResources),
  valuePropositions: fmt(canvas?.valuePropositions),
  customerRelationships: fmt(canvas?.customerRelationships),
  channels: fmt(canvas?.channels),
  customerSegments: fmt(canvas?.customerSegments),
  costStructure: fmt(canvas?.costStructure),
  revenueStreams: fmt(canvas?.revenueStreams),
};

const has = Object.values(blocks).some((b) => b.length > 0);

function Block({ label, items }: { label: string; items: string[] }) {
  return null;
}
---

{has && (
  <figure class="bz-canvas" data-bz-chart>
    <figcaption class="bz-chart__caption bz-label">{t('canvas.caption', lang)}</figcaption>
    <div class="bz-canvas__grid">
      <section class="bz-canvas__cell" style="grid-area: kp;">
        <header class="bz-canvas__head bz-label">{t('canvas.keyPartners', lang)}</header>
        <ul>{blocks.keyPartners.map((v) => <li>{v}</li>)}</ul>
      </section>
      <section class="bz-canvas__cell" style="grid-area: ka;">
        <header class="bz-canvas__head bz-label">{t('canvas.keyActivities', lang)}</header>
        <ul>{blocks.keyActivities.map((v) => <li>{v}</li>)}</ul>
      </section>
      <section class="bz-canvas__cell" style="grid-area: kr;">
        <header class="bz-canvas__head bz-label">{t('canvas.keyResources', lang)}</header>
        <ul>{blocks.keyResources.map((v) => <li>{v}</li>)}</ul>
      </section>
      <section class="bz-canvas__cell bz-canvas__cell--accent" style="grid-area: vp;">
        <header class="bz-canvas__head bz-label">{t('canvas.valuePropositions', lang)}</header>
        <ul>{blocks.valuePropositions.map((v) => <li>{v}</li>)}</ul>
      </section>
      <section class="bz-canvas__cell" style="grid-area: cr;">
        <header class="bz-canvas__head bz-label">{t('canvas.customerRelationships', lang)}</header>
        <ul>{blocks.customerRelationships.map((v) => <li>{v}</li>)}</ul>
      </section>
      <section class="bz-canvas__cell" style="grid-area: ch;">
        <header class="bz-canvas__head bz-label">{t('canvas.channels', lang)}</header>
        <ul>{blocks.channels.map((v) => <li>{v}</li>)}</ul>
      </section>
      <section class="bz-canvas__cell" style="grid-area: cs;">
        <header class="bz-canvas__head bz-label">{t('canvas.customerSegments', lang)}</header>
        <ul>{blocks.customerSegments.map((v) => <li>{v}</li>)}</ul>
      </section>
      <section class="bz-canvas__cell bz-canvas__cell--money" style="grid-area: cost;">
        <header class="bz-canvas__head bz-label">{t('canvas.costStructure', lang)}</header>
        <ul>{blocks.costStructure.map((v) => <li>{v}</li>)}</ul>
      </section>
      <section class="bz-canvas__cell bz-canvas__cell--money" style="grid-area: rev;">
        <header class="bz-canvas__head bz-label">{t('canvas.revenueStreams', lang)}</header>
        <ul>{blocks.revenueStreams.map((v) => <li>{v}</li>)}</ul>
      </section>
    </div>
  </figure>
)}

<style>
  .bz-canvas {
    margin: var(--space-5) 0;
    padding: 0;
  }
  .bz-canvas__grid {
    display: grid;
    grid-template-columns: 1fr;
    grid-template-areas:
      "kp" "ka" "kr" "vp" "cr" "ch" "cs" "cost" "rev";
    gap: var(--space-2);
    background: transparent;
  }
  @media (min-width: 800px) {
    .bz-canvas__grid {
      grid-template-columns: 1fr 1fr 1fr 1fr 1fr;
      grid-template-rows: 1fr 1fr 1fr;
      grid-template-areas:
        "kp ka vp cr cs"
        "kp kr vp ch cs"
        "cost cost cost rev rev";
    }
  }
  .bz-canvas__cell {
    position: relative;
    background: var(--paper);
    padding: var(--space-4) var(--space-4) var(--space-3);
    min-height: 110px;
    border: var(--rule-hairline);
    font-family: var(--font-sans);
    font-size: 0.875rem;
    line-height: 1.5;
  }
  .bz-canvas__cell::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0;
    right: 0;
    height: 3px;
    background: rgba(153, 15, 61, 0.55);
  }
  .bz-canvas__cell--accent { background: rgba(255, 241, 229, 0.9); }
  .bz-canvas__cell--money { background: rgba(242, 223, 206, 0.32); }
  .bz-canvas__head {
    display: block;
    font-variant-caps: all-small-caps;
    letter-spacing: var(--tracking-display-snug);
    font-size: inherit;
    font-weight: 700;
    color: var(--claret);
    border-bottom: 0;
    padding-bottom: 0;
    margin-bottom: var(--space-2);
  }
  .bz-canvas__cell ul {
    list-style: disc;
    padding-left: 1.1em;
    margin: 0;
  }
  .bz-canvas__cell li { margin-bottom: 4px; }
</style>
