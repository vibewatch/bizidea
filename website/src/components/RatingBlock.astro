---
import { t, type Lang } from '../lib/i18n';
interface Dimension { score: number; rationale: string; }
interface Props {
  overall: number;
  lang?: Lang;
  dimensions: {
    market: Dimension;
    differentiation: Dimension;
    execution: Dimension;
    timeliness: Dimension;
  };
}
const { overall, dimensions, lang = 'en' } = Astro.props as Props;
const items: Array<[string, Dimension]> = [
  [t('rating.market', lang), dimensions.market],
  [t('rating.differentiation', lang), dimensions.differentiation],
  [t('rating.execution', lang), dimensions.execution],
  [t('rating.timeliness', lang), dimensions.timeliness],
];
---
<div class="bz-rating">
  <div class="bz-rating__overall">
    <span class="bz-mono bz-rating__label">{t('dossier.overallRating', lang)}</span>
    <span class="bz-rating__score">{overall.toFixed(1)}</span>
    <span class="bz-mono bz-rating__scale">/ 5.0</span>
  </div>
  <ol class="bz-rating__grid">
    {items.map(([name, dim]) => (
      <li class="bz-rating__cell">
        <span class="bz-rating__num">{dim.score}</span>
        <div class="bz-rating__body">
          <span class="bz-mono bz-rating__name">{name}</span>
          <p class="bz-rating__rationale">{dim.rationale}</p>
        </div>
      </li>
    ))}
  </ol>
</div>
<style>
  .bz-rating {
    border-top: var(--rule-thin);
    border-bottom: var(--rule-thin);
    padding: var(--space-5) 0;
    margin: var(--space-5) 0;
  }
  .bz-rating__overall {
    display: flex;
    align-items: baseline;
    gap: var(--space-3);
    margin-bottom: var(--space-5);
  }
  .bz-rating__label { color: var(--caption-gray); }
  .bz-rating__score {
    font-family: var(--font-display);
    font-size: var(--fs-2xl);
    line-height: 1;
    color: var(--ink-page);
  }
  .bz-rating__scale { color: var(--caption-gray); }
  .bz-rating__grid {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-5);
  }
  @media (max-width: 767px) {
    .bz-rating__grid { grid-template-columns: 1fr; }
  }
  .bz-rating__cell {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: var(--space-4);
    border-top: var(--rule-hairline);
    padding-top: var(--space-4);
  }
  .bz-rating__num {
    font-family: var(--font-display);
    font-size: var(--fs-xl);
    line-height: 1;
    color: var(--ink-page);
    min-width: 1.4em;
  }
  .bz-rating__body { display: flex; flex-direction: column; gap: var(--space-1); }
  .bz-rating__name { color: var(--ink-page); font-weight: 700; }
  .bz-rating__rationale {
    font-family: var(--font-sans);
    font-size: var(--fs-base);
    line-height: 1.55;
    margin: 0;
    color: var(--ink-page);
  }
</style>
