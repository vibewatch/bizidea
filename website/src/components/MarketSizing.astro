---
// Nested-circle visualization of TAM / SAM / SOM, with circle area
// proportional to the parsed numeric value. Falls back gracefully when
// values can't be parsed.
import { t, type Lang } from '../lib/i18n';

interface Tier {
  key: 'TAM' | 'SAM' | 'SOM';
  label: string;
  raw?: string | null;
}

interface Props {
  tam?: string | null;
  sam?: string | null;
  som?: string | null;
  lang?: Lang;
}

const { tam, sam, som, lang = 'en' } = Astro.props as Props;

// Parse strings like "$37.5M", "1.2B", "450K", "$2,400" into a number.
function parseValue(s?: string | null): number | null {
  if (!s) return null;
  const m = String(s).match(/(-?\d[\d,]*\.?\d*)\s*([kmbtKMBT])?/);
  if (!m) return null;
  const num = parseFloat(m[1]!.replace(/,/g, ''));
  if (!isFinite(num)) return null;
  const mult: Record<string, number> = { k: 1e3, m: 1e6, b: 1e9, t: 1e12 };
  const u = m[2]?.toLowerCase();
  return num * (u ? (mult[u] ?? 1) : 1);
}

const tiers: Tier[] = [
  { key: 'TAM', label: t('market.tam.long', lang), raw: tam },
  { key: 'SAM', label: t('market.sam.long', lang), raw: sam },
  { key: 'SOM', label: t('market.som.long', lang), raw: som },
];

const parsed = tiers.map((t) => ({ ...t, value: parseValue(t.raw) }));
const tamValue = parsed[0]!.value;
const hasAny = parsed.some((t) => t.value != null && t.value > 0);

// Layout (viewBox units = px when SVG width is capped by max-width).
const VB_W = 720;
const VB_H = 280;
const CX = 150;
const CY = VB_H / 2;
const R_MAX = 110; // outer (TAM) radius

// Radius proportional to sqrt(value / TAM) so AREA encodes value.
function radiusFor(value: number | null): number {
  if (!hasAny || !tamValue || !value || value <= 0) return R_MAX;
  const r = Math.sqrt(value / tamValue) * R_MAX;
  // Floor so SOM never disappears even when ratio is tiny.
  return Math.max(18, Math.min(R_MAX, r));
}

const TONES = {
  tam: '#f2dfce',  // wheat
  sam: '#e3b89c',  // mid
  som: '#990f3d',  // claret
  stroke: '#33302e',
  hairline: '#ccc1b7',
  ink: '#33302e',
  inkMuted: '#66605c',
};

const circles = [
  { key: 'TAM', r: radiusFor(parsed[0]!.value), fill: TONES.tam,  textOn: TONES.ink },
  { key: 'SAM', r: radiusFor(parsed[1]!.value), fill: TONES.sam,  textOn: TONES.ink },
  { key: 'SOM', r: radiusFor(parsed[2]!.value), fill: TONES.som,  textOn: '#fff1e5' },
];

// Labels to the right with leader lines. Each line anchors at the
// intersection of its own circle's perimeter on the ray toward its label,
// so the three lines fan out instead of stacking on the center axis.
const LABEL_X = CX + R_MAX + 60;
const LABEL_GAP = 56;
const LABEL_Y0 = CY - LABEL_GAP;

// Inner-text padding inside the TAM and SAM rings (distance from perimeter
// to the baseline of the chip text).
const CHIP_PAD = 14;
---
<figure class="bz-marketviz" aria-label={t('market.sizing.aria', lang)}>
  <figcaption class="bz-mono bz-marketviz__title">{t('market.sizing', lang)}</figcaption>
  <svg
    class="bz-marketviz__svg"
    viewBox={`0 0 ${VB_W} ${VB_H}`}
    preserveAspectRatio="xMidYMid meet"
    role="img"
  >
    {circles.map((c) => (
      <circle
        cx={CX}
        cy={CY}
        r={c.r}
        fill={c.fill}
        stroke={TONES.stroke}
        stroke-width="1"
        stroke-opacity="0.35"
      />
    ))}

    {circles.map((c, i) => {
      // TAM and SAM sit inside the top of their ring with breathing room;
      // SOM is centered inside the solid disc.
      const innerR = i < 2 ? c.r - circles[i + 1]!.r : 0;
      const ringTop = i < 2
        ? CY - c.r + Math.max(CHIP_PAD, innerR / 2)
        : CY + 5;
      return (
        <text
          x={CX}
          y={ringTop}
          text-anchor="middle"
          class="bz-marketviz__chip"
          fill={c.textOn}
        >{c.key}</text>
      );
    })}

    {parsed.map((t, i) => {
      const ly = LABEL_Y0 + i * LABEL_GAP;
      const cr = circles[i]!.r;
      // Anchor the leader line on this circle's perimeter along the ray
      // pointing at the label, so the three lines diverge.
      const dx = (LABEL_X - 14) - CX;
      const dy = ly - CY;
      const len = Math.hypot(dx, dy) || 1;
      const ax = CX + (dx / len) * cr;
      const ay = CY + (dy / len) * cr;
      return (
        <g>
          <line
            x1={ax}
            y1={ay}
            x2={LABEL_X - 14}
            y2={ly}
            stroke={TONES.stroke}
            stroke-width="1"
          />
          <circle cx={ax} cy={ay} r="2.5" fill={TONES.stroke} />
          <text
            x={LABEL_X}
            y={ly - 8}
            class="bz-marketviz__label"
            fill={TONES.inkMuted}
          >{t.key} · {t.label}</text>
          <text
            x={LABEL_X}
            y={ly + 12}
            class="bz-marketviz__value"
            fill={TONES.ink}
          >{t.raw ?? '—'}</text>
        </g>
      );
    })}
  </svg>
</figure>

<style>
  .bz-marketviz {
    margin: var(--space-3) 0 var(--space-5);
    padding: 0;
    border-bottom: var(--rule-thin);
  }
  .bz-marketviz__title {
    text-align: left;
    color: var(--caption-gray);
    padding: 0 0 var(--space-2);
    margin: 0;
  }
  .bz-marketviz__svg {
    display: block;
    width: 100%;
    max-width: 720px;
    height: auto;
    margin: 0 auto;
    border-top: var(--rule-thin);
    padding-top: var(--space-3);
  }
  .bz-marketviz__chip {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 15px;
    letter-spacing: 0.04em;
  }
  .bz-marketviz__label {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }
  .bz-marketviz__value {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 18px;
    font-variant-numeric: tabular-nums;
  }
  @media (max-width: 560px) {
    .bz-marketviz__svg { max-width: 100%; }
  }
</style>
