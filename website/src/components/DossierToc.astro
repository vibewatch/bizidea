---
// Sticky in-page TOC. Visible only on >=1100px screens (margin space).
// Highlights the active section via IntersectionObserver against [id] anchors.
interface Props {
  items: { id: string; label: string }[];
}
const { items } = Astro.props as Props;
---
<nav class="bz-toc" aria-label="In-page navigation">
  <span class="bz-mono bz-toc__head">In this dossier</span>
  <ol class="bz-toc__list">
    {items.map((it, i) => (
      <li>
        <a href={`#${it.id}`} data-toc-id={it.id}>
          <span class="bz-toc__num">{String(i + 1).padStart(2, '0')}</span>
          <span class="bz-toc__label">{it.label}</span>
        </a>
      </li>
    ))}
  </ol>
</nav>
<script is:inline>
  (() => {
    const links = document.querySelectorAll('.bz-toc a[data-toc-id]');
    if (!links.length) return;
    const byId = new Map();
    const targets = [];
    links.forEach((a) => {
      const id = a.getAttribute('data-toc-id');
      const el = document.getElementById(id);
      if (!el) return;
      byId.set(id, a);
      targets.push(el);
    });
    if (!targets.length) return;
    const setActive = (id) => {
      links.forEach((a) => a.classList.toggle('is-active', a.getAttribute('data-toc-id') === id));
    };
    const io = new IntersectionObserver((entries) => {
      // Pick the entry closest to the top edge of viewport that's intersecting.
      const visible = entries
        .filter((e) => e.isIntersecting)
        .sort((a, b) => a.boundingClientRect.top - b.boundingClientRect.top);
      if (visible.length) setActive(visible[0].target.id);
    }, { rootMargin: '-30% 0px -60% 0px', threshold: [0, 1] });
    targets.forEach((t) => io.observe(t));
  })();
</script>
<style>
  .bz-toc { display: none; }
  @media (min-width: 1180px) {
    .bz-toc {
      position: sticky;
      top: var(--space-4);
      align-self: start;
      display: block;
      font-family: var(--font-sans);
      font-size: var(--fs-sm);
      line-height: 1.4;
      border-top: var(--rule-thin);
      padding: var(--space-5) 0 var(--space-2) var(--space-3);
      max-height: calc(100vh - var(--space-7));
      overflow-y: auto;
    }
  }
  .bz-toc__head {
    display: block;
    color: var(--caption-gray);
    margin-bottom: var(--space-3);
  }
  .bz-toc__list {
    list-style: none;
    margin: 0;
    padding: 0;
  }
  .bz-toc__list li { margin: 0; }
  .bz-toc a {
    display: grid;
    grid-template-columns: 28px 1fr;
    gap: var(--space-2);
    padding: var(--space-1) 0;
    color: var(--caption-gray);
    text-decoration: none;
    border-left: 2px solid transparent;
    margin-left: -16px;
    padding-left: 14px;
    transition: color 120ms ease, border-color 120ms ease;
  }
  .bz-toc a:hover { color: var(--ink-page); }
  .bz-toc a.is-active {
    color: var(--ink-page);
    border-left-color: var(--claret);
  }
  .bz-toc a.is-active .bz-toc__num { color: var(--claret); }
  .bz-toc__num {
    font-family: var(--font-mono);
    font-feature-settings: 'tnum';
    font-size: var(--fs-xs);
    color: var(--disabled-gray);
  }
  .bz-toc__label { font-weight: 500; }
</style>
