---
// Linkifies `[N]`, `[N,N,...]`, and `[N][M][...]` citation tokens into anchors that point at
// the matching `<li id="cite-N">` in the cited-sources bibliography.

import { citationAriaLabel, type Lang } from '../lib/i18n';
import { splitCitationText } from '../lib/citations';

interface Props {
  text?: string | null;
  /** Optional element wrapper, defaults to span. */
  as?: keyof HTMLElementTagNameMap;
  class?: string;
  lang?: Lang;
}
const { text, as: Tag = 'span', class: cls = '', lang = 'en' } = Astro.props as Props;

const parts = splitCitationText(text);
---
<Tag class:list={[cls]}>
  {parts.map((p) =>
    typeof p === 'string'
      ? p
      : <a class="bz-cite" href={`#cite-${p.id}`} aria-label={citationAriaLabel(p.id, lang)}>[{p.id}]</a>
  )}
</Tag>
<style is:global>
  .bz-cite {
    position: relative;
    top: -0.45em;
    color: var(--link-blue);
    text-decoration: none;
    font-family: var(--font-sans);
    font-size: 0.62em;
    letter-spacing: 0em;
    padding: 0;
    margin-left: 1px;
    vertical-align: baseline;
    line-height: 0;
  }
  .bz-cite:hover,
  .bz-cite:focus-visible {
    text-decoration: underline;
  }
  .bz-bib > li:target {
    background: #fff7d6;
    outline: 2px solid var(--ink-page);
    outline-offset: 2px;
  }
</style>
