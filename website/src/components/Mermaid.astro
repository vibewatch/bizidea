---
interface Props {
  code: string;
  title?: string;
}
const { code, title } = Astro.props as Props;
---
<figure class="bz-mermaid">
  {title && <figcaption class="bz-mono bz-mermaid__title">{title}</figcaption>}
  <pre class="mermaid bz-mermaid__src">{code}</pre>
</figure>
<style>
  .bz-mermaid {
    margin: var(--space-5) 0;
    padding: var(--space-4) 0;
    border-top: var(--rule-thin);
    border-bottom: var(--rule-thin);
  }
  .bz-mermaid__title {
    color: var(--caption-gray);
    margin-bottom: var(--space-3);
    display: block;
  }
  .bz-mermaid__src {
    font-family: var(--font-mono);
    font-size: var(--fs-xs);
    margin: 0;
    overflow-x: auto;
    white-space: pre;
    background: var(--paper);
    color: var(--ink-page);
  }
  .bz-mermaid__src :global(svg) {
    max-width: 100%;
    height: auto;
    background: var(--paper);
    display: block;
    margin: 0 auto;
  }

  /* --- Modern Mermaid skin: rounded nodes, soft shadow, refined edges. --- */
  .bz-mermaid__src :global(.node rect),
  .bz-mermaid__src :global(.node polygon),
  .bz-mermaid__src :global(.node circle),
  .bz-mermaid__src :global(.node ellipse),
  .bz-mermaid__src :global(.node path) {
    rx: 10;
    ry: 10;
    filter: drop-shadow(0 1px 0 rgba(51, 48, 46, 0.06))
            drop-shadow(0 4px 10px rgba(51, 48, 46, 0.07));
    stroke-width: 1.25px;
  }
  .bz-mermaid__src :global(.node .label),
  .bz-mermaid__src :global(.nodeLabel) {
    font-family: 'Inter', system-ui, sans-serif !important;
    font-weight: 500;
    color: var(--ink-page) !important;
  }
  .bz-mermaid__src :global(.cluster rect) {
    rx: 14;
    ry: 14;
    stroke-dasharray: 3 4;
    stroke-width: 1px;
  }
  .bz-mermaid__src :global(.cluster .cluster-label),
  .bz-mermaid__src :global(.cluster text) {
    font-family: 'Inter', system-ui, sans-serif !important;
    font-weight: 600;
    font-size: 11px !important;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    fill: var(--caption-gray) !important;
  }
  .bz-mermaid__src :global(.edgePath .path),
  .bz-mermaid__src :global(.flowchart-link) {
    stroke: #807973;
    stroke-width: 1.25px;
  }
  .bz-mermaid__src :global(.arrowheadPath),
  .bz-mermaid__src :global(.marker) {
    fill: #807973;
    stroke: #807973;
  }
  .bz-mermaid__src :global(.edgeLabel) {
    font-family: 'Inter', system-ui, sans-serif !important;
    font-size: 11px !important;
    color: var(--caption-gray) !important;
    background: var(--paper) !important;
    padding: 2px 6px;
  }
  .bz-mermaid__src :global(.edgeLabel rect) {
    fill: var(--paper) !important;
  }

  /* Quadrant chart polish */
  .bz-mermaid__src :global(.quadrant-point-text),
  .bz-mermaid__src :global(.quadrant-x-axis-text-label),
  .bz-mermaid__src :global(.quadrant-y-axis-text-label) {
    font-family: 'Inter', system-ui, sans-serif !important;
    font-weight: 500;
  }
  .bz-mermaid__src :global(.quadrant-title) {
    font-family: 'Bricolage Grotesque', system-ui, sans-serif !important;
    font-weight: 600 !important;
    font-size: 16px !important;
  }
  .bz-mermaid__src :global(.quadrant-point) {
    filter: drop-shadow(0 1px 2px rgba(153, 15, 61, 0.25));
  }

  /* Sequence diagram polish */
  .bz-mermaid__src :global(.actor) {
    rx: 8;
    ry: 8;
    filter: drop-shadow(0 2px 6px rgba(51, 48, 46, 0.08));
  }
  .bz-mermaid__src :global(.messageText) {
    font-family: 'Inter', system-ui, sans-serif !important;
    font-size: 12px !important;
  }
</style>
