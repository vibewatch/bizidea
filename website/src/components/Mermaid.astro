---
interface Props {
  code: string;
  title?: string;
}
const { code, title } = Astro.props as Props;
---
<figure class="bz-mermaid">
  {title && <figcaption class="bz-mono bz-mermaid__title">{title}</figcaption>}
  <pre class="mermaid bz-mermaid__src">{code}</pre>
</figure>
<style>
  .bz-mermaid {
    margin: var(--space-5) 0;
    padding: var(--space-4) 0;
    border-top: var(--rule-thin);
    border-bottom: var(--rule-thin);
  }
  .bz-mermaid__title {
    color: var(--caption-gray);
    margin-bottom: var(--space-3);
    display: block;
  }
  .bz-mermaid__src {
    font-family: var(--font-mono);
    font-size: 0.8125rem;
    margin: 0;
    overflow-x: auto;
    white-space: pre;
    background: var(--paper);
    color: var(--ink-page);
  }
  .bz-mermaid__src :global(svg) {
    max-width: 100%;
    height: auto;
    background: var(--paper);
  }
</style>
