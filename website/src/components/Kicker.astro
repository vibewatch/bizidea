---
interface Props {
  bold?: boolean;
  class?: string;
}
const { bold = false, class: cls = '' } = Astro.props as Props;
---
<span class:list={['bz-kicker', cls, { 'bz-kicker--bold': bold }]}><slot /></span>
<style>
  .bz-kicker {
    font-family: var(--font-mono);
    text-transform: uppercase;
    letter-spacing: 0.92px;
    font-size: 0.8125rem;
    line-height: 1.23;
    color: var(--ink-page);
    display: inline-block;
  }
  .bz-kicker--bold { font-weight: 700; }
</style>
