---
interface Props {
  bold?: boolean;
  class?: string;
}
const { bold = false, class: cls = '' } = Astro.props as Props;
---
<span class:list={['bz-kicker', cls, { 'bz-kicker--bold': bold }]}><slot /></span>
<style>
  /* Eyebrow / kicker — modern sans small-caps in claret, matches `.bz-mono` utility. */
  .bz-kicker {
    font-family: var(--font-sans);
    font-variant-caps: all-small-caps;
    font-weight: 500;
    font-feature-settings: 'cv11';
    letter-spacing: var(--tracking-eyebrow);
    font-size: var(--fs-sm);
    line-height: 1.2;
    color: var(--claret);
    display: inline-block;
  }
  .bz-kicker--bold { font-weight: 700; }
</style>
