---
interface Props {
  label: string;
  id?: string;
}
const { label, id } = Astro.props as Props;
const sectionLabel = /[\u4e00-\u9fff]/.test(label) ? '章节' : 'Section';
---
<section class="bz-ribbon" id={id}>
  <div class="bz-container">
    <span class="bz-ribbon__num">{sectionLabel}</span>
    <h2 class="bz-ribbon__label">{label}</h2>
  </div>
</section>
<style>
  /* Authentic-report section divider: claret rule, auto-numbered "Section 03",
   * display-font label. Replaces the print-era black bar.
   * The section counter is incremented on each .bz-ribbon (set in tokens.css). */
  .bz-ribbon {
    margin: var(--space-5) 0 var(--space-3);
    counter-increment: bz-section;
  }
  .bz-ribbon__num {
    display: block;
    font-family: var(--font-sans);
    font-variant-caps: all-small-caps;
    font-weight: 700;
    letter-spacing: 0.08em;
    font-size: var(--fs-sm);
    color: var(--claret);
    margin-bottom: var(--space-1);
  }
  .bz-ribbon__num::after {
    content: ' ' counter(bz-section, decimal-leading-zero);
    font-feature-settings: 'tnum';
  }
  .bz-ribbon__label {
    display: inline-block;
    margin: 0;
    padding-bottom: var(--space-2);
    font-family: var(--font-display);
    font-weight: 800;
    font-size: clamp(1.5rem, 0.6vw + 1.25rem, 1.875rem);
    line-height: 1.1;
    letter-spacing: var(--tracking-display-tight);
    color: var(--ink-strong);
    text-transform: uppercase;
    border-bottom: 3px solid var(--claret);
  }
</style>
