---
interface Props {
  label: string;
  id?: string;
}
const { label, id } = Astro.props as Props;
---
<section class="bz-ribbon" id={id}>
  <div class="bz-container">
    <span class="bz-ribbon__num">Section</span>
    <h2 class="bz-ribbon__label">{label}</h2>
  </div>
</section>
<style>
  /* Authentic-report section divider: claret rule, auto-numbered "Section 03",
   * display-font label. Replaces the print-era black bar.
   * The section counter is incremented on each .bz-ribbon (set in tokens.css). */
  .bz-ribbon {
    margin: var(--space-8) 0 var(--space-5);
    padding-top: var(--space-3);
    border-top: 2px solid var(--claret);
    counter-increment: bz-section;
  }
  .bz-ribbon__num {
    display: block;
    font-family: var(--font-sans);
    font-variant-caps: all-small-caps;
    font-weight: 600;
    letter-spacing: var(--tracking-eyebrow);
    font-size: var(--fs-sm);
    color: var(--claret);
    margin-bottom: var(--space-1);
  }
  .bz-ribbon__num::after {
    content: ' ' counter(bz-section, decimal-leading-zero);
    font-feature-settings: 'tnum';
  }
  .bz-ribbon__label {
    margin: 0;
    font-family: var(--font-display);
    font-weight: 600;
    font-size: var(--fs-xl);
    line-height: 1.1;
    letter-spacing: var(--tracking-display-tight);
    color: var(--ink-page);
  }
</style>
