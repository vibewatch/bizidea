---
interface Props {
  label: string;
  id?: string;
}
const { label, id } = Astro.props as Props;
---
<section class="bz-ribbon" id={id}>
  <div class="bz-container">
    <span class="bz-ribbon__label">{label}</span>
  </div>
</section>
<style>
  .bz-ribbon {
    background: var(--ink-black);
    color: var(--paper);
    padding: 10px 0;
    margin: var(--space-7) 0 var(--space-5);
    border-top: var(--rule-hard);
    border-bottom: var(--rule-hard);
  }
  .bz-ribbon__label {
    font-family: var(--font-mono);
    text-transform: uppercase;
    letter-spacing: 1.2px;
    font-size: 0.75rem;
    line-height: 1;
    font-weight: 700;
    color: var(--paper);
  }
</style>
