---
// Lazy-loads mermaid.js from jsDelivr only on pages that include this component.
// Keeps the rest of the site JS-free.
---
<script is:inline define:vars={{ }}>
  (function () {
    if (!document.querySelector('pre.mermaid')) return;
    var s = document.createElement('script');
    s.type = 'module';
    s.textContent = [
      "import mermaid from 'https://cdn.jsdelivr.net/npm/mermaid@11/dist/mermaid.esm.min.mjs';",
      "mermaid.initialize({",
      "  startOnLoad: false,",
      "  theme: 'base',",
      "  securityLevel: 'loose',",
      "  fontFamily: 'Inter, Bricolage Grotesque, system-ui, sans-serif',",
      "  flowchart: { useMaxWidth: true, htmlLabels: true, curve: 'basis', padding: 16, nodeSpacing: 56, rankSpacing: 64, diagramPadding: 12 },",
      "  sequence:  { useMaxWidth: true, actorMargin: 60, messageMargin: 40, boxMargin: 12, mirrorActors: false, wrap: true },",
      "  quadrantChart: { chartWidth: 560, chartHeight: 420, titleFontSize: 16, quadrantPadding: 12, quadrantTextTopPadding: 8, pointTextPadding: 6, pointLabelFontSize: 12, xAxisLabelFontSize: 12, yAxisLabelFontSize: 12 },",
      "  themeVariables: {",
      "    fontFamily: 'Inter, Bricolage Grotesque, system-ui, sans-serif',",
      "    fontSize: '14px',",
      "    background: '#fff1e5',",
      "    primaryColor: '#ffffff',",
      "    primaryTextColor: '#33302e',",
      "    primaryBorderColor: '#ccc1b7',",
      "    secondaryColor: '#f7e8d8',",
      "    secondaryBorderColor: '#ccc1b7',",
      "    secondaryTextColor: '#33302e',",
      "    tertiaryColor: '#fff8ef',",
      "    tertiaryBorderColor: '#ccc1b7',",
      "    tertiaryTextColor: '#33302e',",
      "    lineColor: '#807973',",
      "    textColor: '#33302e',",
      "    mainBkg: '#ffffff',",
      "    secondBkg: '#f7e8d8',",
      "    clusterBkg: 'rgba(242,223,206,0.45)',",
      "    clusterBorder: '#ccc1b7',",
      "    edgeLabelBackground: '#fff1e5',",
      "    nodeBorder: '#ccc1b7',",
      "    titleColor: '#33302e',",
      "    quadrant1Fill: '#fdecdc',",
      "    quadrant2Fill: '#f7e8d8',",
      "    quadrant3Fill: '#fff8ef',",
      "    quadrant4Fill: '#fdecdc',",
      "    quadrantTitleFill: '#33302e',",
      "    quadrantPointFill: '#990f3d',",
      "    quadrantPointTextFill: '#33302e',",
      "    quadrantXAxisTextFill: '#66605c',",
      "    quadrantYAxisTextFill: '#66605c',",
      "    quadrantInternalBorderStrokeFill: '#ccc1b7',",
      "    quadrantExternalBorderStrokeFill: '#33302e'",
      "  }",
      "});",
      "mermaid.run({ querySelector: 'pre.mermaid' });"
    ].join('');
    document.head.appendChild(s);
  })();
</script>
