---
// Lazy-loads mermaid.js from jsDelivr only on pages that include this component.
// Keeps the rest of the site JS-free.
---
<script is:inline define:vars={{ }}>
  (function () {
    if (!document.querySelector('pre.mermaid')) return;
    var s = document.createElement('script');
    s.type = 'module';
    s.textContent =
      "import mermaid from 'https://cdn.jsdelivr.net/npm/mermaid@11/dist/mermaid.esm.min.mjs';" +
      "mermaid.initialize({ startOnLoad: false, theme: 'base', flowchart: { useMaxWidth: true }, themeVariables: { fontFamily: 'Inter, Bricolage Grotesque, system-ui, sans-serif', background: '#fff1e5', primaryColor: '#fff1e5', primaryTextColor: '#33302e', primaryBorderColor: '#33302e', secondaryColor: '#f2dfce', tertiaryColor: '#fff1e5', lineColor: '#33302e', textColor: '#33302e', mainBkg: '#fff1e5', secondBkg: '#f2dfce', clusterBkg: '#f2dfce', clusterBorder: '#ccc1b7', edgeLabelBackground: '#fff1e5' } });" +
      "mermaid.run({ querySelector: 'pre.mermaid' });";
    document.head.appendChild(s);
  })();
</script>
