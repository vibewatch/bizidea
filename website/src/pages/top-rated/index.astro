---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Ribbon from '../../components/Ribbon.astro';
import Rule from '../../components/Rule.astro';
import StoryTile from '../../components/StoryTile.astro';
import { t, type Lang } from '../../lib/i18n';
import { buildLocalizedIndexMap, dossierHref, formatRunTimestamp, localizedText, type IdeaEntry, type LocalizedTextField } from '../../lib/page-helpers';
import { sortIdeasTopRatedFirst } from '../../lib/reports';

const lang: Lang = 'en';
const entries = sortIdeasTopRatedFirst(await getCollection('ideas'));
const base = import.meta.env.BASE_URL;
const hrefFor = (entry: IdeaEntry) => dossierHref(entry, lang, base);
const localized = buildLocalizedIndexMap(entries, lang);
const localText = (entry: IdeaEntry, field: LocalizedTextField) => localizedText(entry, localized, field);
---
<BaseLayout
  title={t('top.title', lang)}
  description={t('top.description', lang)}
  lang={lang}
  langSwitchHref={`${base}zh/top-rated/`}
>
  <section class="bz-page-masthead">
    <div class="bz-container">
      <p class="bz-page-masthead__eyebrow bz-label">
        {entries.length} {entries.length === 1 ? t('home.dossierCount.one', lang) : t('home.dossierCount.other', lang)}
      </p>
      <h1 class="bz-page-masthead__title">{t('top.heading', lang)}</h1>
      <p class="bz-page-masthead__deck">{t('top.deck', lang)}</p>
    </div>
  </section>

  <Rule weight="thin" />
  <Ribbon label={t('top.ribbon', lang)} id="top-rated" />

  <div class="bz-container">
    <div class="bz-grid">
      {entries.map((entry) => (
        <StoryTile
          href={hrefFor(entry)}
          kicker={`${localText(entry, 'kicker')} · ${entry.data.sector}`}
          headline={localText(entry, 'pitch')}
          deck={localText(entry, 'topic')}
          meta={`${t('dossier.overallRating', lang)} ${entry.data.rating.overall.toFixed(1)} · ${formatRunTimestamp(entry.data.runTimestamp)}`}
          rating={entry.data.rating}
          lang={lang}
        />
      ))}
    </div>
  </div>
</BaseLayout>

<style>
  .bz-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 0; }
  .bz-grid > :global(*) { border-top: var(--rule-thin); padding-top: var(--space-4); }
  @media (max-width: 1023px) { .bz-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 599px) { .bz-grid { grid-template-columns: 1fr; } }
</style>