---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Ribbon from '../../components/Ribbon.astro';
import Rule from '../../components/Rule.astro';
import StoryTile from '../../components/StoryTile.astro';
import { loadLocalizedIndex } from '../../content/ideas-loader';
import { t, type Lang } from '../../lib/i18n';
import { sortIdeasTopRatedFirst } from '../../lib/reports';

const lang: Lang = 'en';
const entries = sortIdeasTopRatedFirst(await getCollection('ideas'));
const base = import.meta.env.BASE_URL;
const hrefFor = (entry: any) => `${base}${entry.data.folderSlug}/`;

function fmtRunDate(ts: string): string {
  if (!/^\d{14}$/.test(ts)) return ts;
  return `${ts.slice(0, 4)}-${ts.slice(4, 6)}-${ts.slice(6, 8)} ${ts.slice(8, 10)}:${ts.slice(10, 12)}`;
}

const localized = new Map<string, Record<string, unknown> | null>();
for (const entry of entries) {
  localized.set(entry.id, loadLocalizedIndex(entry.id, lang));
}

const localText = (entry: any, field: 'kicker' | 'pitch' | 'topic') => {
  const idx = localized.get(entry.id);
  const val = idx?.[field];
  return typeof val === 'string' && val.length > 0 ? val : entry.data[field];
};
---
<BaseLayout
  title={t('top.title', lang)}
  description={t('top.description', lang)}
  lang={lang}
  langSwitchHref={`${base}zh/top-rated/`}
>
  <section class="bz-top-masthead">
    <div class="bz-container">
      <p class="bz-top-masthead__eyebrow bz-mono">
        {entries.length} {entries.length === 1 ? t('home.dossierCount.one', lang) : t('home.dossierCount.other', lang)}
      </p>
      <h1 class="bz-top-masthead__title">{t('top.heading', lang)}</h1>
      <p class="bz-top-masthead__deck">{t('top.deck', lang)}</p>
    </div>
  </section>

  <Rule weight="thin" />
  <Ribbon label={t('top.ribbon', lang)} id="top-rated" />

  <div class="bz-container">
    <div class="bz-grid">
      {entries.map((entry) => (
        <StoryTile
          href={hrefFor(entry)}
          kicker={`${localText(entry, 'kicker')} · ${entry.data.sector}`}
          headline={localText(entry, 'pitch')}
          deck={localText(entry, 'topic')}
          meta={`${t('dossier.overallRating', lang)} ${entry.data.rating.overall.toFixed(1)} · ${fmtRunDate(entry.data.runTimestamp)}`}
          rating={entry.data.rating}
          lang={lang}
        />
      ))}
    </div>
  </div>
</BaseLayout>

<style>
  .bz-top-masthead { padding-block: var(--space-5) var(--space-3); }
  .bz-top-masthead__eyebrow { color: var(--caption-gray); margin: 0 0 var(--space-2); }
  .bz-top-masthead__title {
    font-family: var(--font-display);
    font-size: var(--fs-xl);
    line-height: 1.16;
    letter-spacing: var(--tracking-display-snug);
    font-weight: 700;
    color: var(--ink-page);
    margin: var(--space-2) 0;
    max-width: 34ch;
  }
  .bz-top-masthead__deck {
    font-family: var(--font-sans);
    font-size: var(--fs-md);
    line-height: 1.55;
    max-width: 60ch;
    color: var(--ink-page);
    margin-bottom: 0;
  }
  .bz-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 0 var(--space-6); }
  .bz-grid > :global(*) { border-top: var(--rule-thin); padding-top: var(--space-4); }
  @media (max-width: 1023px) { .bz-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 599px) { .bz-grid { grid-template-columns: 1fr; } }
</style>