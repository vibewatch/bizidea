---
import { getCollection } from 'astro:content';
import DossierPage from '../../ideas/[run]/index.astro';
import { hasZhTranslation } from '../../../content/ideas-loader';

export async function getStaticPaths() {
  const all = await getCollection('ideas');
  return all
    .filter((entry) => hasZhTranslation(entry.id))
    .map((entry) => ({
      params: { run: entry.data.folderSlug },
      props: { entry, lang: 'zh' as const },
    }));
}

const { entry, lang } = Astro.props;
---

<DossierPage entry={entry} lang={lang} />
