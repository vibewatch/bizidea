---
import { getCollection } from 'astro:content';
import SectorsIndexPage from '../../../components/SectorsIndexPage.astro';
import { hasZhTranslation } from '../../../content/ideas-loader';
import type { Lang } from '../../../lib/i18n';
import { groupIdeasBySector } from '../../../lib/reports';

const lang: Lang = 'zh';
const entries = (await getCollection('ideas')).filter((entry) => hasZhTranslation(entry.id));
const sectorGroups = groupIdeasBySector(entries, lang);
const base = import.meta.env.BASE_URL;
---

<SectorsIndexPage sectorGroups={sectorGroups} lang={lang} langSwitchHref={`${base}sectors/`} />
