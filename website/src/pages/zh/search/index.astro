---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import SearchExperience from '../../../components/SearchExperience.astro';
import { t, type Lang } from '../../../lib/i18n';

const lang: Lang = 'zh';
const base = import.meta.env.BASE_URL;
---
<BaseLayout
  title={t('search.title', lang)}
  description={t('search.description', lang)}
  lang={lang}
  langSwitchHref={`${base}search/`}
>
  <SearchExperience lang={lang} indexUrl={`${base}zh/search-index.json`} />
</BaseLayout>