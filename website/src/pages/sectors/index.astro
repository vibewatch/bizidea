---
import { getCollection } from 'astro:content';
import SectorsIndexPage from '../../components/SectorsIndexPage.astro';
import type { Lang } from '../../lib/i18n';
import { groupIdeasBySector } from '../../lib/reports';

const lang: Lang = 'en';
const entries = await getCollection('ideas');
const sectorGroups = groupIdeasBySector(entries, lang);
const base = import.meta.env.BASE_URL;
---

<SectorsIndexPage sectorGroups={sectorGroups} lang={lang} langSwitchHref={`${base}zh/sectors/`} />
