---
import { getCollection } from 'astro:content';
import ArchiveIndexPage from '../../components/ArchiveIndexPage.astro';
import type { Lang } from '../../lib/i18n';
import { groupIdeasByMonth, sortIdeasNewestFirst } from '../../lib/reports';

const lang: Lang = 'en';
const all = await getCollection('ideas');
const sorted = sortIdeasNewestFirst(all);
const monthGroups = groupIdeasByMonth(sorted, lang);
const base = import.meta.env.BASE_URL;
---

<ArchiveIndexPage totalCount={sorted.length} monthGroups={monthGroups} lang={lang} langSwitchHref={`${base}zh/archive/`} />
