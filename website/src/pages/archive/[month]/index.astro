---
import { getCollection } from 'astro:content';
import ArchiveMonthPage from '../../../components/ArchiveMonthPage.astro';
import { hasZhTranslation } from '../../../content/ideas-loader';
import type { Lang } from '../../../lib/i18n';
import type { IdeaEntry } from '../../../lib/page-helpers';
import { groupIdeasByMonth } from '../../../lib/reports';

const lang: Lang = 'en';

export async function getStaticPaths() {
  const all = await getCollection('ideas');
  const zhMonthSlugs = new Set(groupIdeasByMonth(all.filter((entry) => hasZhTranslation(entry.id)), 'zh').map((month) => month.slug));
  return groupIdeasByMonth(all, 'en').map((month) => ({
    params: { month: month.slug },
    props: { entries: month.entries, monthSlug: month.slug, monthLabel: month.label, hasZhMonth: zhMonthSlugs.has(month.slug) },
  }));
}

const { entries: rawEntries, monthSlug, monthLabel, hasZhMonth } = Astro.props;
const entries = rawEntries as IdeaEntry[];
const base = import.meta.env.BASE_URL;
const langSwitchHref = hasZhMonth ? `${base}zh/archive/${monthSlug}/` : `${base}zh/archive/`;
---

<ArchiveMonthPage entries={entries} monthLabel={monthLabel} lang={lang} langSwitchHref={langSwitchHref} />
