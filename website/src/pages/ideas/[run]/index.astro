---
import { getCollection } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Kicker from '../../../components/Kicker.astro';
import Headline from '../../../components/Headline.astro';
import Ribbon from '../../../components/Ribbon.astro';
import Rule from '../../../components/Rule.astro';
import RatingBlock from '../../../components/RatingBlock.astro';
import FactRow from '../../../components/FactRow.astro';
import MarketSizing from '../../../components/MarketSizing.astro';
import MarketMap from '../../../components/MarketMap.astro';
import Mermaid from '../../../components/Mermaid.astro';
import MermaidLoader from '../../../components/MermaidLoader.astro';
import FinancialCharts from '../../../components/FinancialCharts.astro';
import IdeaScorecard from '../../../components/IdeaScorecard.astro';
import RiskHeatmap from '../../../components/RiskHeatmap.astro';
import BusinessModelCanvas from '../../../components/BusinessModelCanvas.astro';
import CitedText from '../../../components/CitedText.astro';
import RatingSparkline from '../../../components/RatingSparkline.astro';
import DossierToc from '../../../components/DossierToc.astro';
import { loadLocalizedIndex, loadStageFiles } from '../../../content/ideas-loader';
import { linkifyCitations } from '../../../lib/citations';
import { t, type Lang } from '../../../lib/i18n';

export async function getStaticPaths() {
  return [];
}

const { entry: rawEntry, lang: rawLang = 'en' } = Astro.props;
const lang: Lang = rawLang === 'zh' ? 'zh' : 'en';
const otherLang: Lang = lang === 'en' ? 'zh' : 'en';
const localizedIndex = loadLocalizedIndex(rawEntry.id, lang);
const entry = { ...rawEntry, data: { ...rawEntry.data, ...(localizedIndex ?? {}) } };
const base = import.meta.env.BASE_URL;
const prefixFor = (l: Lang) => (l === 'zh' ? `${base}zh/` : base);
const stages = loadStageFiles(entry.id, lang);
const idea = stages.idea as any;
const research = stages.research as any;
const bp = stages.businessPlan as any;
const fm = stages.financialModel as any;

const fmtK = (k: number) =>
  (k >= 1000 || k <= -1000)
    ? `$${(k / 1000).toFixed(2)}M`
    : `$${k.toFixed(0)}K`;

const tocItems = [
  { id: 'why-now', label: t('section.whyNow', lang) },
  { id: 'idea', label: t('section.idea', lang) },
  { id: 'market', label: t('section.market', lang) },
  { id: 'competition', label: t('section.competition', lang) },
  { id: 'business-plan', label: t('section.businessPlan', lang) },
  { id: 'financial-model', label: t('section.financialModel', lang) },
  { id: 'risks', label: t('section.topRisks', lang) },
  { id: 'evidence', label: t('section.evidence', lang) },
];

const zhUiLabels: Record<string, string> = {
  'Beachhead': '滩头市场',
  'Wedge': '切入点',
  'Non-obvious insight': '非显而易见洞察',
  'Venture-scale path': '风险投资级路径',
  'Primary user': '主要用户',
  'Secondary user': '次要用户',
  'Economic buyer': '经济买方',
  'First customer': '首个客户',
  'Buying trigger': '购买触发点',
  'Current alternative': '当前替代方案',
  'Switching reason': '切换理由',
  'Pricing hypothesis': '定价假设',
  'Jobs to be done': '待完成任务',
  'Job': '任务',
  'Success metric': '成功指标',
  'Executive takeaways': '高管要点',
  'Market definition': '市场定义',
  'Customer and buyer': '用户与买方',
  'Buying triggers': '购买触发点',
  'Willingness to pay': '支付意愿',
  'Category dynamics': '品类动态',
  'Growth signal': '增长信号',
  'Tailwinds': '顺风因素',
  'Headwinds': '逆风因素',
  'Validation signals': '验证信号',
  'Regulatory & technical constraints': '监管与技术约束',
  'Adoption friction': '采用阻力',
  'Friction': '阻力',
  'Severity': '严重度',
  'Affected buyer': '受影响买方',
  'Mitigation': '缓解措施',
  'Competitor': '竞争对手',
  'Stage': '阶段',
  'Pricing': '定价',
  'Strength': '优势',
  'Weakness vs. us': '相对劣势',
  'Why incumbents do not win by default': '为什么现有厂商不会默认胜出',
  'Problem': '问题',
  'Solution': '解决方案',
  'Why we win': '为什么我们会赢',
  'Strategic choices': '战略选择',
  'Wedge rationale': '切入点理由',
  'Sequencing': '推进顺序',
  'Not yet': '暂不进入',
  'Go-to-market': '进入市场',
  'Channels': '渠道',
  'Funnel targets': '漏斗目标',
  'Product roadmap': '产品路线图',
  '6 months': '6 个月',
  '12 months': '12 个月',
  '24 months': '24 个月',
  'Key bets': '关键押注',
  'Business model': '商业模式',
  'Revenue streams': '收入来源',
  'Unit of value': '价值单位',
  'Target gross margin': '目标毛利率',
  'Expansion levers': '扩张杠杆',
  'Strategy map': '战略地图',
  'North-star metric': '北极星指标',
  'Input metrics': '输入指标',
  'Moats to build': '待构建护城河',
  'Kill criteria': '终止标准',
  'Milestones': '里程碑',
  'Founding team': '创始团队',
  'Role': '角色',
  'Start timing': '入职时间',
  'Rationale': '理由',
  'Experiment roadmap': '实验路线图',
  'Horizon': '阶段',
  'Experiment': '实验',
  'Hypothesis': '假设',
  'Owner': '负责人',
  'Risk assessment': '风险评估',
  'Risk': '风险',
  'Likelihood': '可能性',
  'Impact': '影响',
  'Title': '标题',
  'Profile': '画像',
  'Trigger': '触发点',
  'Buyer': '买方',
  'Initial contract': '初始合同',
  'What must be true': '必须成立的条件',
  'Open diligence questions': '待尽调问题',
  'Investor verdict': '投资人判断',
  'Call': '结论',
  'Conviction': '信心',
  'Why believe': '相信的理由',
  'Why doubt': '怀疑的理由',
  'Next diligence': '下一步尽调',
  '3-year totals': '三年合计',
  'Year 1 revenue': '第 1 年收入',
  'Year 2 revenue': '第 2 年收入',
  'Year 3 revenue': '第 3 年收入',
  'Unit economics': '单位经济',
  'ARPU (annual)': '年 ARPU',
  'Gross margin': '毛利率',
  'Payback': '回本期',
  'LTV': '生命周期价值',
  'Funding ask': '融资需求',
  'Round': '轮次',
  'Runway': '跑道',
  'Milestone': '里程碑',
  'Model sanity': '模型合理性',
  'Scenarios': '情景',
  'Scenario': '情景',
  'Y3 revenue': '第 3 年收入',
  'Y3 EBITDA': '第 3 年 EBITDA',
  'Cash low point': '现金低点',
  'Description': '说明',
  'Key changes': '关键变化',
  'Sensitivity': '敏感性',
  'Variable': '变量',
  'Downside': '下行情景',
  'Base': '基准情景',
  'Upside': '上行情景',
  'Key assumptions': '关键假设',
  'ID': 'ID',
  'Name': '名称',
  'Value': '数值',
  'Unit': '单位',
  'Source': '来源',
  'Flags': '警示项',
  'Business plan risks': '商业计划风险',
  'mapped': '已映射',
};
const ui = (label: string) => lang === 'zh' ? (zhUiLabels[label] ?? label) : label;
---
<BaseLayout
  title={`${(idea?.pitch ?? entry.data.pitch)} — Bizidea`}
  description={idea?.pitch ?? entry.data.pitch}
  lang={lang}
  langSwitchHref={`${prefixFor(otherLang)}${entry.data.folderSlug}/`}
>
  <article class="bz-story">
    <header class="bz-story__head bz-container">
      <div class="bz-story__topbar">
        <p class="bz-story__strap bz-mono">
          <span class="bz-story__strap-section">{entry.data.kicker}</span>
          <span class="bz-story__strap-sep" aria-hidden="true">·</span>
          <span>{entry.data.sector}</span>
          <span class="bz-story__strap-sep" aria-hidden="true">·</span>
          <span>Scan {entry.data.scan.timeWindow}</span>
          <span class="bz-story__strap-sep" aria-hidden="true">·</span>
          <span>Run {entry.data.runTimestamp}</span>
        </p>
        <button class="bz-print-btn" type="button" data-print-dossier>{t('dossier.export', lang)}</button>
      </div>
      <div class="bz-story__masthead">
        <div class="bz-story__masthead-main">
          <Headline as="h1" size="hero">{entry.data.pitch}</Headline>
          {idea?.problem && (
            <p class="bz-story__deck">{String(idea.problem).split(/(?<=\.)\s+/).slice(0, 2).join(' ')}</p>
          )}
          <p class="bz-story__byline">
            <span class="bz-story__author">{t('dossier.byline', lang)}</span>
            <span class="bz-story__sep" aria-hidden="true">/</span>
            <time datetime={entry.data.date}>{entry.data.date}</time>
          </p>
        </div>
        <aside class="bz-story__kpis" aria-label="At a glance">
          <div class="bz-story__kpi bz-story__kpi--rating">
            <span class="bz-mono">{t('dossier.rating', lang)}</span>
            <RatingSparkline
              dimensions={entry.data.rating.dimensions}
              overall={entry.data.rating.overall}
              size="md"
            />
            <span class="bz-story__kpi-legend bz-mono">{t('dossier.rating.legend', lang)}</span>
          </div>
          <div class="bz-story__kpi">
            <span class="bz-mono">{t('dossier.som', lang)}</span>
            <span class="bz-story__kpi-num">{entry.data.market?.som ?? '—'}</span>
          </div>
          <div class="bz-story__kpi">
            <span class="bz-mono">{t('dossier.funding', lang)}</span>
            <span class="bz-story__kpi-num">${entry.data.financials?.fundingAsk?.amountM?.toFixed(1) ?? '—'}M</span>
            <span class="bz-story__kpi-sub">{entry.data.financials?.fundingAsk?.round}</span>
          </div>
          <div class="bz-story__kpi">
            <span class="bz-mono">{t('dossier.y3Revenue', lang)}</span>
            <span class="bz-story__kpi-num">{fmtK(entry.data.financials?.y3?.revenueK ?? 0)}</span>
            <span class="bz-story__kpi-sub">EBITDA {fmtK(entry.data.financials?.y3?.ebitdaK ?? 0)}</span>
          </div>
        </aside>
      </div>
    </header>

    <div class="bz-container">
      <RatingBlock overall={entry.data.rating.overall} dimensions={entry.data.rating.dimensions} lang={lang} />
    </div>

    <div class="bz-story__layout">
      <DossierToc items={tocItems} heading={t('dossier.toc', lang)} />
      <div class="bz-story__main">

    <Ribbon label={t('section.whyNow', lang)} id="why-now" />
    <div class="bz-container bz-section">
      {Array.isArray(idea?.whyNow) && (
        <ol class="bz-list">
          {idea.whyNow.map((w: any) => (
            <li><CitedText text={w.point} /></li>
          ))}
        </ol>
      )}
      <p class="bz-story__lead"><strong>{t('label.catalyst', lang)}</strong> <CitedText text={idea?.startupThesis?.whyNowCatalyst} /></p>
    </div>

    <Ribbon label={t('section.idea', lang)} id="idea" />
    <div class="bz-container bz-section">
      <p class="bz-story__lead">{idea?.solution}</p>
      {idea?.differentiator && (
        <p class="bz-story__lead bz-lead--quiet"><strong>{t('label.whatsDifferent', lang)}</strong> {idea.differentiator}</p>
      )}
      <FactRow
        caption={t('label.startupThesis', lang)}
        rows={[
          { label: ui('Beachhead'), value: idea?.startupThesis?.beachhead ?? null },
          { label: ui('Wedge'), value: idea?.startupThesis?.wedge ?? null },
          { label: ui('Non-obvious insight'), value: idea?.startupThesis?.nonObviousInsight ?? null },
          { label: ui('Venture-scale path'), value: idea?.startupThesis?.ventureScalePath ?? null },
        ]}
      />
      {idea?.targetUser && (
        <FactRow
          caption={t('label.targetUser', lang)}
          rows={[
            { label: ui('Primary user'), value: idea.targetUser.primary ?? null },
            { label: ui('Secondary user'), value: idea.targetUser.secondary ?? null },
            { label: ui('Economic buyer'), value: idea.targetUser.buyer ?? null },
          ]}
        />
      )}
      {idea?.goToMarketSeed && (
        <FactRow
          caption={t('label.gtmSeed', lang)}
          rows={[
            { label: ui('First customer'), value: idea.goToMarketSeed.firstCustomer ?? null },
            { label: ui('Buying trigger'), value: idea.goToMarketSeed.buyingTrigger ?? null },
            { label: ui('Current alternative'), value: idea.goToMarketSeed.currentAlternative ?? null },
            { label: ui('Switching reason'), value: idea.goToMarketSeed.switchingReason ?? null },
            { label: ui('Pricing hypothesis'), value: idea.goToMarketSeed.pricingHypothesis ?? null },
          ]}
        />
      )}
      {Array.isArray(idea?.jobsToBeDone) && idea.jobsToBeDone.length > 0 && (
        <>
          <h3 class="bz-section__head">{ui('Jobs to be done')}</h3>
          <table class="bz-comp">
            <thead>
              <tr>
                <th class="bz-mono">{ui('Job')}</th>
                <th class="bz-mono">{ui('Current alternative')}</th>
                <th class="bz-mono">{ui('Success metric')}</th>
              </tr>
            </thead>
            <tbody>
              {idea.jobsToBeDone.map((j: any) => (
                <tr>
                  <td>{j.job}</td>
                  <td>{j.currentAlternative}</td>
                  <td>{j.successMetric}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </>
      )}
      {idea?.conceptDiagram?.mermaid && (
        <Mermaid title={idea.conceptDiagram.title} code={idea.conceptDiagram.mermaid} />
      )}
      {idea?.ideaScorecard && (
        <IdeaScorecard scorecard={idea.ideaScorecard} lang={lang} />
      )}
      {idea?.businessModelCanvas && (
        <BusinessModelCanvas canvas={idea.businessModelCanvas} lang={lang} />
      )}
    </div>

    <Ribbon label={t('section.market', lang)} id="market" />
    <div class="bz-container bz-section">
      <div class="bz-market-grid">
        <MarketSizing
          tam={research?.market?.tam?.value ?? null}
          sam={research?.market?.sam?.value ?? null}
          som={research?.market?.som?.value ?? null}
          lang={lang}
        />
        <FactRow
          caption={t('label.marketSizing', lang)}
          rows={[
            { label: 'TAM', value: research?.market?.tam?.value ?? null, subHtml: linkifyCitations(research?.market?.tam?.rationale) },
            { label: 'SAM', value: research?.market?.sam?.value ?? null, subHtml: linkifyCitations(research?.market?.sam?.rationale) },
            { label: 'SOM', value: research?.market?.som?.value ?? null, subHtml: linkifyCitations(research?.market?.som?.rationale) },
          ]}
        />
      </div>
      {research?.reportMemo?.executiveTakeaways && (
        <>
          <h3 class="bz-section__head">{ui('Executive takeaways')}</h3>
          <ul class="bz-list">
            {research.reportMemo.executiveTakeaways.map((t: string) => <li><CitedText text={t} /></li>)}
          </ul>
        </>
      )}
      {research?.reportMemo?.marketDefinition && (
        <>
          <h3 class="bz-section__head">{ui('Market definition')}</h3>
          <p class="bz-story__lead"><CitedText text={research.reportMemo.marketDefinition} /></p>
        </>
      )}
      {research?.reportMemo?.customerAndBuyer && (
        <>
          <h3 class="bz-section__head">{ui('Customer and buyer')}</h3>
          <p class="bz-story__lead"><CitedText text={research.reportMemo.customerAndBuyer} /></p>
        </>
      )}
      {Array.isArray(research?.reportMemo?.buyingTriggers) && research.reportMemo.buyingTriggers.length > 0 && (
        <>
          <h3 class="bz-section__head">{ui('Buying triggers')}</h3>
          <ul class="bz-list">
            {research.reportMemo.buyingTriggers.map((t: any) => (
              <li>
                <CitedText text={t.point} />
                {Array.isArray(t.sourceRefs) && t.sourceRefs.length > 0 && (
                  <span class="bz-cite-trail"> {t.sourceRefs.map((id: number) => (
                    <a class="bz-cite" href={`#cite-${id}`} aria-label={`Citation ${id}`}>[{id}]</a>
                  ))}</span>
                )}
              </li>
            ))}
          </ul>
        </>
      )}
      {research?.reportMemo?.willingnessToPay?.summary && (
        <>
          <h3 class="bz-section__head">{ui('Willingness to pay')}</h3>
          <p class="bz-story__lead">
            <CitedText text={research.reportMemo.willingnessToPay.summary} />
            {Array.isArray(research.reportMemo.willingnessToPay.sourceRefs) && research.reportMemo.willingnessToPay.sourceRefs.length > 0 && (
              <span class="bz-cite-trail"> {research.reportMemo.willingnessToPay.sourceRefs.map((id: number) => (
                <a class="bz-cite" href={`#cite-${id}`} aria-label={`Citation ${id}`}>[{id}]</a>
              ))}</span>
            )}
          </p>
        </>
      )}
      {research?.categoryDynamics && (research.categoryDynamics.tailwinds || research.categoryDynamics.headwinds) && (
        <>
          <h3 class="bz-section__head">{ui('Category dynamics')}</h3>
          {research.categoryDynamics.growthRate && (
            <p class="bz-mini-meta"><span class="bz-mono">{ui('Growth signal')}</span> {research.categoryDynamics.growthRate}</p>
          )}
          <div class="bz-twocol">
            {Array.isArray(research.categoryDynamics.tailwinds) && (
              <section>
                <h4 class="bz-mini-head bz-mini-head--up">{ui('Tailwinds')}</h4>
                <ul class="bz-list">
                  {research.categoryDynamics.tailwinds.map((t: any) => (
                    <li><CitedText text={t.point} /></li>
                  ))}
                </ul>
              </section>
            )}
            {Array.isArray(research.categoryDynamics.headwinds) && (
              <section>
                <h4 class="bz-mini-head bz-mini-head--down">{ui('Headwinds')}</h4>
                <ul class="bz-list">
                  {research.categoryDynamics.headwinds.map((t: any) => (
                    <li><CitedText text={t.point} /></li>
                  ))}
                </ul>
              </section>
            )}
          </div>
        </>
      )}
      {Array.isArray(research?.validationSignals) && research.validationSignals.length > 0 && (
        <>
          <h3 class="bz-section__head">{ui('Validation signals')}</h3>
          <ul class="bz-list">
            {research.validationSignals.map((s: any) => (
              <li><CitedText text={s.point} /></li>
            ))}
          </ul>
        </>
      )}
      {Array.isArray(research?.regulatoryTechnicalConstraints) && research.regulatoryTechnicalConstraints.length > 0 && (
        <>
          <h3 class="bz-section__head">{ui('Regulatory & technical constraints')}</h3>
          <ul class="bz-list">
            {research.regulatoryTechnicalConstraints.map((c: any) => (
              <li><CitedText text={c.point} /></li>
            ))}
          </ul>
        </>
      )}
      {Array.isArray(research?.adoptionFrictionMatrix) && research.adoptionFrictionMatrix.length > 0 && (
        <>
          <h3 class="bz-section__head">{ui('Adoption friction')}</h3>
          <table class="bz-comp">
            <thead>
              <tr>
                <th class="bz-mono">{ui('Friction')}</th>
                <th class="bz-mono">{ui('Severity')}</th>
                <th class="bz-mono">{ui('Affected buyer')}</th>
                <th class="bz-mono">{ui('Mitigation')}</th>
              </tr>
            </thead>
            <tbody>
              {research.adoptionFrictionMatrix.map((f: any) => (
                <tr>
                  <td>{f.friction}</td>
                  <td><span class={`bz-pill bz-pill--${(f.severity ?? 'medium').toLowerCase()}`}>{f.severity}</span></td>
                  <td>{f.affectedBuyer}</td>
                  <td>{f.mitigation}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </>
      )}
      {Array.isArray(research?.pestle) && research.pestle.length > 0 && (
        <>
          <h3 class="bz-section__head">PESTLE</h3>
          <ul class="bz-pestle">
            {research.pestle.map((p: any) => (
              <li class={`bz-pestle__item bz-pestle__item--${(p.impact ?? 'neutral').toLowerCase()}`}>
                <span class="bz-pestle__factor bz-mono">{p.factor}</span>
                <span class="bz-pestle__point"><CitedText text={p.point} /></span>
              </li>
            ))}
          </ul>
        </>
      )}
      {research?.analysisModels?.marketMapDiagram?.mermaid && (
        <MarketMap
          title={research.analysisModels.marketMapDiagram.title}
          mermaid={research.analysisModels.marketMapDiagram.mermaid}
          lang={lang}
        />
      )}
    </div>

    <Ribbon label={t('section.competition', lang)} id="competition" />
    <div class="bz-container bz-section">
      {research?.reportMemo?.competitiveLandscape && (
        <p class="bz-story__lead"><CitedText text={research.reportMemo.competitiveLandscape} /></p>
      )}
      {Array.isArray(research?.competitors) && (
        <table class="bz-comp">
          <thead>
            <tr>
              <th class="bz-mono">Competitor</th>
              <th class="bz-mono">Stage</th>
              <th class="bz-mono">Wedge</th>
              <th class="bz-mono">Pricing</th>
              <th class="bz-mono">Strength</th>
              <th class="bz-mono">Weakness vs. us</th>
            </tr>
          </thead>
          <tbody>
            {research.competitors.map((c: any) => (
              <tr>
                <td>{c.name}</td>
                <td>{c.stage}</td>
                <td>{c.wedge}</td>
                <td>{c.pricing ?? '—'}</td>
                <td>{c.strength ?? '—'}</td>
                <td>{c.weaknessVsUs}</td>
              </tr>
            ))}
          </tbody>
        </table>
      )}
      {Array.isArray(research?.reportMemo?.incumbentThesis) && (
        <>
          <h3 class="bz-section__head">Why incumbents do not win by default</h3>
          <ul class="bz-list">
            {research.reportMemo.incumbentThesis.map((i: any) => (
              <li><strong>{i.incumbentClass}.</strong> <CitedText text={i.point} /></li>
            ))}
          </ul>
        </>
      )}
      {research?.fiveForces && (
        <>
          <h3 class="bz-section__head">Porter's five forces</h3>
          <ul class="bz-forces">
            {[
              { key: 'supplierPower', label: 'Supplier power' },
              { key: 'buyerPower', label: 'Buyer power' },
              { key: 'threatOfEntrants', label: 'Threat of entrants' },
              { key: 'threatOfSubstitutes', label: 'Threat of substitutes' },
              { key: 'competitiveRivalry', label: 'Competitive rivalry' },
            ].filter(({ key }) => research.fiveForces[key]).map(({ key, label }) => {
              const f = research.fiveForces[key];
              const pct = Math.max(0, Math.min(100, ((f.score ?? 0) / 5) * 100));
              return (
                <li class="bz-force">
                  <span class="bz-force__label bz-mono">{label}</span>
                  <span class="bz-force__bar"><span class="bz-force__bar-fill" style={`width:${pct}%`}></span></span>
                  <span class="bz-force__score">{f.score ?? '—'} / 5</span>
                  <span class="bz-force__note"><CitedText text={f.rationale} /></span>
                </li>
              );
            })}
          </ul>
        </>
      )}
    </div>

    <Ribbon label={t('section.businessPlan', lang)} id="business-plan" />
    <div class="bz-container bz-section">
      <p class="bz-story__lead">{bp?.executiveSummary}</p>
