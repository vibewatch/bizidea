                  <td><span class={`bz-pill bz-pill--${(r.impact ?? 'medium').toLowerCase()}`}>{r.impact}</span></td>
                  <td>{r.mitigation}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </>
      )}
      {bp?.investorMemo?.firstCustomer && (
        <FactRow
          caption={ui('First customer')}
          rows={[
            { label: ui('Title'), value: bp.investorMemo.firstCustomer.title ?? null },
            { label: ui('Profile'), value: bp.investorMemo.firstCustomer.profile ?? null },
            { label: ui('Trigger'), value: bp.investorMemo.firstCustomer.trigger ?? null },
            { label: ui('Buyer'), value: bp.investorMemo.firstCustomer.buyer ?? null },
            { label: ui('Initial contract'), value: bp.investorMemo.firstCustomer.initialContract ?? null },
          ]}
        />
      )}
      {Array.isArray(bp?.investorMemo?.mustBeTrue) && bp.investorMemo.mustBeTrue.length > 0 && (
        <>
          <h3 class="bz-section__head">{ui('What must be true')}</h3>
          <ul class="bz-list">
            {bp.investorMemo.mustBeTrue.map((s: string) => <li>{s}</li>)}
          </ul>
        </>
      )}
      {Array.isArray(bp?.investorMemo?.diligenceQuestions) && bp.investorMemo.diligenceQuestions.length > 0 && (
        <>
          <h3 class="bz-section__head">{ui('Open diligence questions')}</h3>
          <ul class="bz-list">
            {bp.investorMemo.diligenceQuestions.map((q: string) => <li>{q}</li>)}
          </ul>
        </>
      )}
      {bp?.investorMemo?.verdict && (
        <FactRow
          caption={ui('Investor verdict')}
          rows={[
            { label: ui('Call'), value: bp.investorMemo.verdict.call ?? null },
            { label: ui('Conviction'), value: bp.investorMemo.verdict.conviction ?? null },
            { label: ui('Why believe'), value: bp.investorMemo.verdict.whyBelieve ?? null },
            { label: ui('Why doubt'), value: bp.investorMemo.verdict.whyDoubt ?? null },
            { label: ui('Next diligence'), value: bp.investorMemo.verdict.nextDiligence ?? null },
          ]}
        />
      )}
    </div>

    <FinancialModelSection fm={fm} lang={lang} />

    <Ribbon label={t('section.topRisks', lang)} id="risks" />
    <div class="bz-container bz-section">
      {Array.isArray(idea?.topRisks) && idea.topRisks.length > 0 && typeof idea.topRisks[0] === 'object' ? (
        <ul class="bz-list">
          {idea.topRisks.map((r: any) => (
            <li>
              <strong>{r.name}.</strong> {r.description} {r.mitigation && (<><em class="bz-mute">{ui('Mitigation')}:</em> {r.mitigation}</>)}
            </li>
          ))}
        </ul>
      ) : (
        <ul class="bz-list">
          {entry.data.topRisks.map((r) => <li>{r}</li>)}
        </ul>
      )}
    </div>

    <Ribbon label={t('section.evidence', lang)} id="evidence" />
    <div class="bz-container bz-section">
      <div class="bz-evidence-grid">
        {Array.isArray(research?.sources) && (
          <section>
            <h3 class="bz-section__head">{t('dossier.citedSources', lang)} ({research.sources.length})</h3>
            <ol class="bz-bib">
              {research.sources.map((s: any) => (
                <li id={`cite-${s.id}`}>
                  <strong>{s.publisher}.</strong> {s.title}
                  {s.url && <span> · <a href={s.url} target="_blank" rel="noopener noreferrer">{s.url}</a></span>}
                </li>
              ))}
            </ol>
          </section>
        )}
      </div>
    </div>
      </div>
    </div>
  </article>
  <RelatedDossiers base={base} entries={relatedEntries} lang={lang} localized={relatedLocalized} />
  <script is:inline>
    document.querySelector('[data-print-dossier]')?.addEventListener('click', () => window.print());
  </script>
  <MermaidLoader />
</BaseLayout>

