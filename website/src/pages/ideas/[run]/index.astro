---
import { getCollection } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Headline from '../../../components/Headline.astro';
import RatingBlock from '../../../components/RatingBlock.astro';
import MermaidLoader from '../../../components/MermaidLoader.astro';
import DossierBusinessPlanSection from '../../../components/DossierBusinessPlanSection.astro';
import DossierCompetitionSection from '../../../components/DossierCompetitionSection.astro';
import DossierEvidenceSection from '../../../components/DossierEvidenceSection.astro';
import DossierIdeaSection from '../../../components/DossierIdeaSection.astro';
import DossierMarketSection from '../../../components/DossierMarketSection.astro';
import FinancialModelSection from '../../../components/FinancialModelSection.astro';
import RatingSparkline from '../../../components/RatingSparkline.astro';
import DossierToc from '../../../components/DossierToc.astro';
import RelatedDossiers from '../../../components/RelatedDossiers.astro';
import { hasZhTranslation, loadLocalizedIndex, loadStageFiles } from '../../../content/ideas-loader';
import { formatMoneyK, uiLabel } from '../../../lib/dossier-format';
import { localizeFundingRound, localizeSector, t, type Lang } from '../../../lib/i18n';
import { buildLocalizedIndexMap, languagePrefix } from '../../../lib/page-helpers';
import { findRelatedDossiers, RELATED_DOSSIER_LIMIT } from '../../../lib/reports';
import '../../../styles/dossier.css';

export async function getStaticPaths() {
  // Shared implementation template only. Public static routes are generated by
  // src/pages/[run]/index.astro and src/pages/zh/[run]/index.astro.
  return [];
}

const { entry: rawEntry, lang: rawLang = 'en' } = Astro.props;
const lang: Lang = rawLang === 'zh' ? 'zh' : 'en';
const otherLang: Lang = lang === 'en' ? 'zh' : 'en';
const localizedIndex = loadLocalizedIndex(rawEntry.id, lang);
const entry = { ...rawEntry, data: { ...rawEntry.data, ...(localizedIndex ?? {}) } };
const base = import.meta.env.BASE_URL;
const prefixFor = (l: Lang) => languagePrefix(base, l);
const langSwitchHref = lang === 'en' && !hasZhTranslation(rawEntry.id)
  ? `${base}zh/`
  : `${prefixFor(otherLang)}${entry.data.folderSlug}/`;
const stages = loadStageFiles(entry.id, lang);
const idea = stages.idea;
const research = stages.research;
const bp = stages.businessPlan;
const fm = stages.financialModel;
const sectorLabel = localizeSector(String(entry.data.sector ?? ''), lang);
const topFundingRoundLabel = localizeFundingRound(String(entry.data.financials?.fundingAsk?.round ?? ''), lang);
const atGlanceLabel = t('common.atGlance', lang);
const relatedPool = (await getCollection('ideas')).filter((candidate) => lang === 'en' || hasZhTranslation(candidate.id));
const relatedEntries = findRelatedDossiers(rawEntry, relatedPool, RELATED_DOSSIER_LIMIT);
const relatedLocalized = buildLocalizedIndexMap(relatedEntries, lang);

const fmtK = formatMoneyK;
const ui = (label: string) => uiLabel(label, lang);

const tocItems = [
  { id: 'why-now', label: t('section.whyNow', lang) },
  { id: 'idea', label: t('section.idea', lang) },
  { id: 'market', label: t('section.market', lang) },
  { id: 'competition', label: t('section.competition', lang) },
  { id: 'business-plan', label: t('section.businessPlan', lang) },
  { id: 'financial-model', label: t('section.financialModel', lang) },
  { id: 'risks', label: t('section.topRisks', lang) },
  { id: 'evidence', label: t('section.evidence', lang) },
];

---
<BaseLayout
  title={`${(idea?.pitch ?? entry.data.pitch)} — Bizidea`}
  description={idea?.pitch ?? entry.data.pitch}
  lang={lang}
  langSwitchHref={langSwitchHref}
>
  <article class="bz-story">
    <header class="bz-story__head bz-container">
      <div class="bz-story__topbar">
        <p class="bz-story__strap bz-label">
          <span class="bz-story__strap-section">{entry.data.kicker}</span>
          <span class="bz-story__strap-sep" aria-hidden="true">·</span>
          <span>{sectorLabel}</span>
          <span class="bz-story__strap-sep" aria-hidden="true">·</span>
          <span>{ui('Scan')} {entry.data.scan.timeWindow}</span>
          <span class="bz-story__strap-sep" aria-hidden="true">·</span>
          <span>{ui('Run')} {entry.data.runTimestamp}</span>
        </p>
        <button class="bz-print-btn" type="button" data-print-dossier>{t('dossier.export', lang)}</button>
      </div>
      <div class="bz-story__masthead">
        <div class="bz-story__masthead-main">
          <Headline as="h1" size="hero">{entry.data.pitch}</Headline>
          {idea?.problem && (
            <p class="bz-story__deck">{String(idea.problem).split(/(?<=\.)\s+/).slice(0, 2).join(' ')}</p>
          )}
          <p class="bz-story__byline">
            <span class="bz-story__author">{t('dossier.byline', lang)}</span>
            <span class="bz-story__sep" aria-hidden="true">/</span>
            <time datetime={entry.data.date}>{entry.data.date}</time>
          </p>
        </div>
        <aside class="bz-story__kpis" aria-label={atGlanceLabel}>
          <div class="bz-story__kpi bz-story__kpi--rating">
            <span class="bz-label">{t('dossier.rating', lang)}</span>
            <RatingSparkline
              dimensions={entry.data.rating.dimensions}
              overall={entry.data.rating.overall}
              size="md"
              lang={lang}
            />
            <span class="bz-story__kpi-legend bz-label">{t('dossier.rating.legend', lang)}</span>
          </div>
          <div class="bz-story__kpi">
            <span class="bz-label">{t('dossier.som', lang)}</span>
            <span class="bz-story__kpi-num">{entry.data.market?.som ?? '—'}</span>
          </div>
          <div class="bz-story__kpi">
            <span class="bz-label">{t('dossier.funding', lang)}</span>
            <span class="bz-story__kpi-num">${entry.data.financials?.fundingAsk?.amountM?.toFixed(1) ?? '—'}M</span>
            <span class="bz-story__kpi-sub">{topFundingRoundLabel}</span>
          </div>
          <div class="bz-story__kpi">
            <span class="bz-label">{t('dossier.y3Revenue', lang)}</span>
            <span class="bz-story__kpi-num">{fmtK(entry.data.financials?.y3?.revenueK ?? 0)}</span>
            <span class="bz-story__kpi-sub">EBITDA {fmtK(entry.data.financials?.y3?.ebitdaK ?? 0)}</span>
          </div>
        </aside>
      </div>
    </header>

    <div class="bz-container">
      <RatingBlock overall={entry.data.rating.overall} dimensions={entry.data.rating.dimensions} lang={lang} />
    </div>

    <div class="bz-story__layout">
      <DossierToc items={tocItems} heading={t('dossier.toc', lang)} />
      <div class="bz-story__main">

    <DossierIdeaSection idea={idea} lang={lang} />

    <DossierMarketSection research={research} lang={lang} />

    <DossierCompetitionSection research={research} lang={lang} />

    <DossierBusinessPlanSection bp={bp} lang={lang} />

    <FinancialModelSection fm={fm} lang={lang} />

    <DossierEvidenceSection idea={idea} research={research} topRisks={entry.data.topRisks} lang={lang} />
      </div>
    </div>
  </article>
  <RelatedDossiers base={base} entries={relatedEntries} lang={lang} localized={relatedLocalized} />
  <script is:inline>
    document.querySelector('[data-print-dossier]')?.addEventListener('click', () => window.print());
  </script>
  <MermaidLoader />
</BaseLayout>

