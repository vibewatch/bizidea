            </tbody>
          </table>
        </>
      )}
      {Array.isArray(bp?.experimentRoadmap) && bp.experimentRoadmap.length > 0 && (
        <>
          <h3 class="bz-section__head">{ui('Experiment roadmap')}</h3>
          <table class="bz-comp">
            <thead>
              <tr>
                <th class="bz-label">{ui('Horizon')}</th>
                <th class="bz-label">{ui('Experiment')}</th>
                <th class="bz-label">{ui('Hypothesis')}</th>
                <th class="bz-label">{ui('Success metric')}</th>
                <th class="bz-label">{ui('Owner')}</th>
              </tr>
            </thead>
            <tbody>
              {bp.experimentRoadmap.map((e: any) => (
                <tr>
                  <td class="bz-label">{e.horizon}</td>
                  <td>{e.experiment}</td>
                  <td>{e.hypothesis}</td>
                  <td>{e.successMetric}</td>
                  <td>{e.owner}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </>
      )}
      {Array.isArray(bp?.risks) && bp.risks.length > 0 && (
