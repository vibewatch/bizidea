            <thead>
              <tr>
                <th class="bz-label">{ui('Risk')}</th>
                <th class="bz-label">{ui('Likelihood')}</th>
                <th class="bz-label">{ui('Impact')}</th>
                <th class="bz-label">{ui('Mitigation')}</th>
