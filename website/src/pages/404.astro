---
import BaseLayout from '../layouts/BaseLayout.astro';
import Ribbon from '../components/Ribbon.astro';
const base = import.meta.env.BASE_URL;
---
<BaseLayout title="404 — Bizidea">
  <Ribbon label="404 / off the presses" />
  <div class="bz-container bz-404">
    <h1>This dossier is not in the archive.</h1>
    <p>
      <a href={base}>← Back to the newsstand</a>
    </p>
  </div>
</BaseLayout>
<style>
  .bz-404 { padding: var(--space-7) 0 var(--space-9); }
  .bz-404 h1 {
    font-family: var(--font-display);
    font-size: var(--fs-2xl);
    line-height: var(--lh-display-block);
    color: var(--ink-page);
    margin: 0 0 var(--space-4);
  }
</style>
