---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import Kicker from '../components/Kicker.astro';
import Headline from '../components/Headline.astro';
import Ribbon from '../components/Ribbon.astro';
import Rule from '../components/Rule.astro';
import StoryTile from '../components/StoryTile.astro';
import RatingSparkline from '../components/RatingSparkline.astro';

const all = await getCollection('ideas');
const sorted = all.sort((a, b) => b.data.runTimestamp.localeCompare(a.data.runTimestamp));
const [hero, ...rest] = sorted;

const base = import.meta.env.BASE_URL;
const hrefFor = (entry: any) => `${base}ideas/${entry.data.folderSlug}/`;

function fmtRunDate(ts: string): string {
  // YYYYMMDDHHmmss → "YYYY-MM-DD HH:mm UTC"
  if (!/^\d{14}$/.test(ts)) return ts;
  return `${ts.slice(0, 4)}-${ts.slice(4, 6)}-${ts.slice(6, 8)} ${ts.slice(8, 10)}:${ts.slice(10, 12)}`;
}

const latestLabel = hero ? fmtRunDate(hero.data.runTimestamp) : '';
const issueNo = sorted.length;
---
<BaseLayout
  title="Bizidea — Startup Dossiers"
  description="AI-generated startup research dossiers — triage, idea, market, plan, financial model."
>
  <section class="bz-masthead">
    <div class="bz-container">
      <div class="bz-masthead__strap">
        <span class="bz-mono">Vol. I · No. {issueNo} · {latestLabel}</span>
        <span class="bz-mono bz-masthead__strap-right">{sorted.length} dossier{sorted.length === 1 ? '' : 's'}</span>
      </div>
      <h1 class="bz-masthead__title">
        <span>Startup news,</span>
        <span>read like a venture memo.</span>
      </h1>
      <p class="bz-masthead__deck">
        Each dossier walks a triaged news topic through idea synthesis, market
        research, business plan, financial model, and a structured rating — all
        generated end-to-end by specialist agents.
      </p>
    </div>
  </section>

  <Rule weight="thin" />

  {hero && (
    <section class="bz-hero">
      <div class="bz-container bz-hero__layout">
        <div class="bz-hero__copy">
          <Kicker bold>{hero.data.kicker} · {hero.data.sector}</Kicker>
          <Headline as="h2" size="hero" href={hrefFor(hero)}>
            {hero.data.pitch}
          </Headline>
          <p class="bz-hero__deck">{hero.data.topic}</p>
        </div>
        <aside class="bz-hero__panel" aria-label="At a glance">
          <div class="bz-hero__panel-head">
            <span class="bz-mono">Rating</span>
            <RatingSparkline
              dimensions={hero.data.rating.dimensions}
              overall={hero.data.rating.overall}
              size="md"
            />
            <span class="bz-hero__panel-legend bz-mono">Mkt · Diff · Exec · Time</span>
          </div>
          <dl class="bz-hero__facts">
            <div><dt class="bz-mono">SOM</dt><dd>{hero.data.market.som ?? '—'}</dd></div>
            <div><dt class="bz-mono">Funding ask</dt><dd>${hero.data.financials.fundingAsk.amountM.toFixed(1)}M <span class="bz-hero__facts-sub">{hero.data.financials.fundingAsk.round}</span></dd></div>
            <div><dt class="bz-mono">Scan</dt><dd>{hero.data.scan.timeWindow}</dd></div>
          </dl>
          <a href={hrefFor(hero)} class="bz-hero__panel-cta bz-mono">Read full dossier →</a>
        </aside>
      </div>
    </section>
  )}

  <Ribbon label="More dossiers" id="more-dossiers" />

  {rest.length === 0 ? (
    <div class="bz-container">
      <p class="bz-empty bz-mono">No additional dossiers yet — generate one with the Bizidea agent.</p>
    </div>
  ) : (
    <div class="bz-container">
      <div class="bz-grid">
        {rest.map((entry) => (
          <StoryTile
            href={hrefFor(entry)}
            kicker={`${entry.data.kicker} · ${entry.data.sector}`}
            headline={entry.data.pitch}
            deck={entry.data.topic}
            meta={fmtRunDate(entry.data.runTimestamp)}
            rating={entry.data.rating}
          />
        ))}
      </div>
    </div>
  )}
</BaseLayout>

<style>
  .bz-masthead { padding-block: var(--space-8) var(--space-5); }
  .bz-masthead__strap {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: var(--space-3);
    padding-bottom: var(--space-3);
    margin-bottom: var(--space-4);
    border-bottom: var(--rule-thin);
    color: var(--caption-gray);
  }
  .bz-masthead__strap .bz-mono { color: var(--caption-gray); }
  .bz-masthead__strap-right { color: var(--ink-page); }
  .bz-masthead__title {
    font-family: var(--font-display);
    font-size: var(--fs-3xl);
    line-height: var(--lh-display-hero);
    letter-spacing: var(--tracking-display-tight);
    font-weight: 600;
    color: var(--ink-page);
    margin: var(--space-3) 0;
    max-width: 22ch;
  }
  .bz-masthead__title span { display: block; }
  .bz-masthead__deck {
    font-family: var(--font-sans);
    font-size: var(--fs-md);
    line-height: 1.55;
    max-width: 60ch;
    color: var(--ink-page);
  }

  .bz-hero { padding-block: var(--space-6) var(--space-7); }
  .bz-hero__layout {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-6);
    align-items: start;
  }
  @media (min-width: 900px) {
    .bz-hero__layout { grid-template-columns: minmax(0, 1.6fr) minmax(0, 1fr); gap: var(--space-7); }
  }
  .bz-hero__copy { display: flex; flex-direction: column; gap: var(--space-3); min-width: 0; }
  .bz-hero__deck {
    font-family: var(--font-sans);
    font-size: var(--fs-md);
    line-height: 1.55;
    color: var(--ink-page);
    margin: 0;
    max-width: 65ch;
  }
  .bz-hero__panel {
    background: var(--paper-wheat);
    border-top: 3px solid var(--claret);
    padding: var(--space-4) var(--space-4) var(--space-3);
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }
  .bz-hero__panel-head {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }
  .bz-hero__panel-head .bz-mono { color: var(--caption-gray); }
  .bz-hero__panel-legend { color: var(--caption-gray); font-size: var(--fs-xs); }
  .bz-hero__facts {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-3);
    margin: 0;
    padding: var(--space-3) 0 0;
    border-top: var(--rule-hairline);
  }
  .bz-hero__facts > div {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: var(--space-3);
  }
  .bz-hero__facts dt { color: var(--caption-gray); }
  .bz-hero__facts dd {
    margin: 0;
    font-family: var(--font-display);
    font-size: var(--fs-lg);
    line-height: 1.15;
    color: var(--ink-page);
    font-feature-settings: 'tnum';
    text-align: right;
  }
  .bz-hero__facts-sub {
    font-family: var(--font-sans);
    font-weight: 500;
    font-size: var(--fs-xs);
    color: var(--caption-gray);
    text-transform: lowercase;
  }
  .bz-hero__panel-cta {
    display: inline-block;
    color: var(--claret);
    text-decoration: none;
    border-top: var(--rule-hairline);
    padding-top: var(--space-3);
  }
  .bz-hero__panel-cta:hover { color: var(--ink-page); }

  .bz-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 0 var(--space-6);
  }
  .bz-grid > :global(*) {
    border-top: var(--rule-thin);
    padding-top: var(--space-4);
  }
  @media (max-width: 1023px) {
    .bz-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 599px) {
    .bz-grid { grid-template-columns: 1fr; }
  }

  .bz-empty {
    color: var(--caption-gray);
    padding-block: var(--space-7);
    text-align: center;
  }
</style>
