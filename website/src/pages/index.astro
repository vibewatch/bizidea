---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import Kicker from '../components/Kicker.astro';
import Headline from '../components/Headline.astro';
import Ribbon from '../components/Ribbon.astro';
import Rule from '../components/Rule.astro';
import StoryTile from '../components/StoryTile.astro';

const all = await getCollection('ideas');
const sorted = all.sort((a, b) => b.data.runTimestamp.localeCompare(a.data.runTimestamp));
const [hero, ...rest] = sorted;

const base = import.meta.env.BASE_URL;
const hrefFor = (id: string) => `${base}ideas/${id}/`;

function fmtRunDate(ts: string): string {
  // YYYYMMDDHHmmss → "YYYY-MM-DD HH:mm UTC"
  if (!/^\d{14}$/.test(ts)) return ts;
  return `${ts.slice(0, 4)}-${ts.slice(4, 6)}-${ts.slice(6, 8)} ${ts.slice(8, 10)}:${ts.slice(10, 12)}`;
}

const latestLabel = hero ? fmtRunDate(hero.data.runTimestamp) : '';
---
<BaseLayout
  title="Bizidea — Startup Dossiers"
  description="AI-generated startup research dossiers — news, idea, market, plan, financial model."
>
  <section class="bz-masthead">
    <div class="bz-container">
      <Kicker class="bz-masthead__eyebrow">Bizidea Dossiers · Updated {latestLabel}</Kicker>
      <h1 class="bz-masthead__title">
        <span>Startup news,</span>
        <span>read like a venture memo.</span>
      </h1>
      <p class="bz-masthead__deck">
        Each dossier walks a single news topic through six stages — scout, idea,
        market research, business plan, financial model, and a structured rating —
        all generated end-to-end by specialist agents.
      </p>
    </div>
  </section>

  <Rule weight="thin" />

  {hero && (
    <section class="bz-hero">
      <div class="bz-container bz-hero__grid">
        <a class="bz-hero__media" href={hrefFor(hero.id)} aria-hidden="true">
          <div class="bz-hero__placeholder">
            <span class="bz-mono">{hero.data.kicker} · {hero.data.sector.toUpperCase()}</span>
          </div>
        </a>
        <div class="bz-hero__copy">
          <Kicker bold>{hero.data.kicker} · {hero.data.sector}</Kicker>
          <Headline as="h2" size="hero" href={hrefFor(hero.id)}>
            {hero.data.pitch}
          </Headline>
          <p class="bz-hero__deck">{hero.data.topic}</p>
          <dl class="bz-hero__facts">
            <div><dt class="bz-mono">Rating</dt><dd>{hero.data.rating.overall.toFixed(1)} / 5.0</dd></div>
            <div><dt class="bz-mono">SOM</dt><dd>{hero.data.market.som ?? '—'}</dd></div>
            <div><dt class="bz-mono">Funding ask</dt><dd>${hero.data.financials.fundingAsk.amountM.toFixed(1)}M {hero.data.financials.fundingAsk.round}</dd></div>
            <div><dt class="bz-mono">Scan</dt><dd>{hero.data.scan.timeWindow}</dd></div>
          </dl>
        </div>
      </div>
    </section>
  )}

  <Ribbon label="More dossiers" />

  {rest.length === 0 ? (
    <div class="bz-container">
      <p class="bz-empty bz-mono">No additional dossiers yet — generate one with the Bizidea agent.</p>
    </div>
  ) : (
    <div class="bz-container">
      <div class="bz-grid">
        {rest.map((entry) => (
          <StoryTile
            href={hrefFor(entry.id)}
            kicker={`${entry.data.kicker} · ${entry.data.sector}`}
            headline={entry.data.pitch}
            deck={entry.data.topic}
            meta={`Rated ${entry.data.rating.overall.toFixed(1)} · ${fmtRunDate(entry.data.runTimestamp)}`}
          />
        ))}
      </div>
    </div>
  )}
</BaseLayout>

<style>
  .bz-masthead { padding: var(--space-8) 0 var(--space-5); }
  .bz-masthead__eyebrow { color: var(--caption-gray); }
  .bz-masthead__title {
    font-family: var(--font-display);
    font-size: clamp(2.5rem, 6vw, 4.5rem);
    line-height: var(--lh-display-hero);
    letter-spacing: -0.5px;
    color: var(--ink-page);
    margin: var(--space-3) 0;
  }
  .bz-masthead__title span { display: block; }
  .bz-masthead__deck {
    font-family: var(--font-serif);
    font-size: 1.1875rem;
    line-height: 1.47;
    max-width: 60ch;
    color: var(--ink-page);
  }

  .bz-hero { padding: var(--space-6) 0 var(--space-7); }
  .bz-hero__grid {
    display: grid;
    grid-template-columns: 1.05fr 1fr;
    gap: var(--space-7);
    align-items: start;
  }
  @media (max-width: 899px) {
    .bz-hero__grid { grid-template-columns: 1fr; gap: var(--space-5); }
  }
  .bz-hero__media {
    display: block;
    aspect-ratio: 16 / 9;
    background: var(--ink-black);
    color: var(--paper);
    text-decoration: none;
  }
  .bz-hero__placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: flex-end;
    justify-content: flex-start;
    padding: var(--space-4);
    color: var(--paper);
    background:
      repeating-linear-gradient(
        135deg,
        #0e0e0e 0,
        #0e0e0e 14px,
        #161616 14px,
        #161616 28px
      );
  }
  .bz-hero__placeholder .bz-mono { color: var(--paper); }
  .bz-hero__copy { display: flex; flex-direction: column; gap: var(--space-3); }
  .bz-hero__deck {
    font-family: var(--font-serif);
    font-size: 1.1875rem;
    line-height: 1.47;
    color: var(--ink-page);
    margin: 0;
  }
  .bz-hero__facts {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: var(--space-3) var(--space-4);
    margin: var(--space-3) 0 0;
    padding: var(--space-4) 0 0;
    border-top: var(--rule-thin);
  }
  .bz-hero__facts > div { display: flex; flex-direction: column; gap: 2px; }
  .bz-hero__facts dt { color: var(--caption-gray); }
  .bz-hero__facts dd {
    margin: 0;
    font-family: var(--font-display);
    font-size: 1.25rem;
    line-height: 1.15;
    color: var(--ink-page);
  }

  .bz-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 0 var(--space-6);
  }
  .bz-grid > :global(*) {
    border-top: var(--rule-thin);
    padding-top: var(--space-4);
  }
  @media (max-width: 1023px) {
    .bz-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 599px) {
    .bz-grid { grid-template-columns: 1fr; }
  }

  .bz-empty {
    color: var(--caption-gray);
    padding: var(--space-7) 0;
    text-align: center;
  }
</style>
