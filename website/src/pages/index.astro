---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import Kicker from '../components/Kicker.astro';
import Headline from '../components/Headline.astro';
import Ribbon from '../components/Ribbon.astro';
import Rule from '../components/Rule.astro';
import StoryTile from '../components/StoryTile.astro';
import RatingSparkline from '../components/RatingSparkline.astro';
import { localizeFundingRound, t, type Lang } from '../lib/i18n';
import { buildLocalizedIndexMap, dossierHref, formatRunTimestamp, localizedText, type IdeaEntry, type LocalizedTextField } from '../lib/page-helpers';
import { HOMEPAGE_REPORT_LIMIT, sortIdeasNewestFirst } from '../lib/reports';

const lang: Lang = 'en';
const all = await getCollection('ideas');
const sorted = sortIdeasNewestFirst(all);
const [hero, ...allRest] = sorted;
const rest = allRest.slice(0, Math.max(HOMEPAGE_REPORT_LIMIT - 1, 0));
const hiddenCount = Math.max(sorted.length - HOMEPAGE_REPORT_LIMIT, 0);

const base = import.meta.env.BASE_URL;
const hrefFor = (entry: IdeaEntry) => dossierHref(entry, lang, base);
const localized = buildLocalizedIndexMap(sorted, lang);
const localText = (entry: IdeaEntry, field: LocalizedTextField) => localizedText(entry, localized, field);
---
<BaseLayout
  title={t('home.title', lang)}
  description={t('home.description', lang)}
  lang={lang}
  langSwitchHref={`${base}zh/`}
>
  <section class="bz-page-masthead">
    <div class="bz-container">
      <p class="bz-page-masthead__eyebrow bz-label">{t('footer.tag', lang)}</p>
      <h1 class="bz-page-masthead__title">
        <span>{t('home.headline.line1', lang)}</span>
        <span>{t('home.headline.line2', lang)}</span>
      </h1>
      <p class="bz-page-masthead__deck">
        {t('home.deck', lang)}
      </p>
    </div>
  </section>

  <Rule weight="thin" />

  {hero && (
    <section class="bz-hero">
      <div class="bz-container bz-hero__layout">
        <div class="bz-hero__copy">
          <Kicker bold>{localText(hero, 'kicker')} · {hero.data.sector}</Kicker>
          <Headline as="h2" size="block" class="bz-hero__headline" href={hrefFor(hero)}>
            {localText(hero, 'pitch')}
          </Headline>
          <p class="bz-hero__deck">{localText(hero, 'topic')}</p>
        </div>
        <aside class="bz-hero__panel" aria-label={t('common.atGlance', lang)}>
          <div class="bz-hero__panel-head">
            <span class="bz-label">{t('home.rating', lang)}</span>
            <RatingSparkline
              dimensions={hero.data.rating.dimensions}
              overall={hero.data.rating.overall}
              size="md"
              lang={lang}
            />
            <span class="bz-hero__panel-legend bz-label">{t('home.rating.legend', lang)}</span>
          </div>
          <dl class="bz-hero__facts">
            <div><dt class="bz-label">{t('home.som', lang)}</dt><dd>{hero.data.market.som ?? '—'}</dd></div>
            <div><dt class="bz-label">{t('home.funding', lang)}</dt><dd>${hero.data.financials.fundingAsk.amountM.toFixed(1)}M <span class="bz-hero__facts-sub">{localizeFundingRound(String(hero.data.financials.fundingAsk.round ?? ''), lang)}</span></dd></div>
            <div><dt class="bz-label">{t('home.scan', lang)}</dt><dd>{hero.data.scan.timeWindow}</dd></div>
          </dl>
          <a href={hrefFor(hero)} class="bz-hero__panel-cta bz-label">{t('home.read', lang)}</a>
        </aside>
      </div>
    </section>
  )}

  <Ribbon label={t('home.more', lang)} id="more-dossiers" />

  {rest.length === 0 ? (
    <div class="bz-container">
      <p class="bz-empty bz-label">{t('home.empty', lang)}</p>
    </div>
  ) : (
    <div class="bz-container">
      <div class="bz-grid">
        {rest.map((entry) => (
          <StoryTile
            href={hrefFor(entry)}
            kicker={`${localText(entry, 'kicker')} · ${entry.data.sector}`}
            headline={localText(entry, 'pitch')}
            deck={localText(entry, 'topic')}
            meta={formatRunTimestamp(entry.data.runTimestamp)}
            rating={entry.data.rating}
            lang={lang}
          />
        ))}
      </div>
      {hiddenCount > 0 && (
        <div class="bz-home-archive-cta">
          <a href={`${base}archive/`} class="bz-home-archive-button bz-label">
            {t('home.viewAll', lang)}
          </a>
          <span class="bz-home-archive-cta__meta bz-label">
            {hiddenCount} {hiddenCount === 1 ? t('home.dossierCount.one', lang) : t('home.dossierCount.other', lang)} {t('home.hiddenSuffix', lang)}
          </span>
        </div>
      )}
    </div>
  )}
</BaseLayout>

<style>
  .bz-hero { padding-block: var(--space-5) var(--space-7); }
  .bz-hero__layout {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-6);
    align-items: start;
  }
  @media (min-width: 900px) {
    .bz-hero__layout { grid-template-columns: minmax(0, 1.6fr) minmax(0, 1fr); gap: var(--space-7); }
  }
  .bz-hero__copy { display: flex; flex-direction: column; gap: var(--space-4); min-width: 0; }
  .bz-hero__headline {
    font-size: clamp(1.75rem, 1.7vw + 1.1rem, 2.5rem);
    line-height: 1.1;
    letter-spacing: var(--tracking-display-tight);
    font-weight: 800;
    color: var(--ink-strong);
    max-width: 30ch;
    text-wrap: balance;
  }
  .bz-hero__deck {
    font-family: var(--font-sans);
    font-size: var(--fs-md);
    line-height: 1.55;
    color: var(--caption-gray);
    margin: 0;
    max-width: 60ch;
    text-wrap: pretty;
  }
  .bz-hero__panel {
    background: linear-gradient(180deg, var(--paper-soft), var(--paper-wheat));
    border-top: 3px solid var(--claret);
    box-shadow: var(--shadow-card);
    padding: var(--space-5);
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }
  .bz-hero__panel-head {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }
  .bz-hero__panel .bz-label {
    font-size: var(--fs-sm);
    line-height: 1.3;
  }
  .bz-hero__panel-head .bz-label { color: var(--caption-gray); letter-spacing: 0.06em; }
  .bz-hero__panel-legend { color: var(--caption-gray); font-size: var(--fs-xs); letter-spacing: 0.04em; }
  .bz-hero__facts {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-3);
    margin: 0;
    padding: var(--space-4) 0 0;
    border-top: var(--rule-hairline);
  }
  .bz-hero__facts > div {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: var(--space-3);
    flex-wrap: wrap;
  }
  .bz-hero__facts dt { color: var(--caption-gray); letter-spacing: 0.06em; }
  .bz-hero__facts dd {
    margin: 0;
    font-family: var(--font-display);
    font-weight: 700;
    font-size: clamp(1rem, 0.4vw + 0.9rem, 1.25rem);
    line-height: 1.2;
    color: var(--ink-strong);
    font-feature-settings: 'tnum';
    text-align: right;
  }
  .bz-hero__facts-sub {
    font-family: var(--font-sans);
    font-weight: 500;
    font-size: var(--fs-sm);
    color: var(--caption-gray);
    text-transform: lowercase;
    letter-spacing: 0.02em;
  }
  .bz-hero__panel-cta {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    color: var(--claret);
    text-decoration: none;
    border-top: var(--rule-hairline);
    padding-top: var(--space-3);
    font-weight: 700;
  }
  .bz-hero__panel-cta::after {
    content: '→';
    transition: transform 160ms ease;
  }
  .bz-hero__panel-cta:hover { color: var(--claret-deep); }
  .bz-hero__panel-cta:hover::after { transform: translateX(3px); }

  .bz-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 0;
  }
  .bz-grid > :global(*) {
    border-top: var(--rule-thin);
    padding-top: var(--space-4);
  }
  @media (max-width: 1023px) {
    .bz-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 599px) {
    .bz-grid { grid-template-columns: 1fr; }
  }

  .bz-empty {
    color: var(--caption-gray);
    padding-block: var(--space-7);
    text-align: center;
  }

  .bz-home-archive-button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-2);
    background: var(--claret);
    color: var(--paper);
    padding: var(--space-3) var(--space-5);
    font-size: var(--fs-base);
    font-weight: 700;
    line-height: 1.2;
    text-decoration: none;
    white-space: nowrap;
    transition: background 140ms ease, transform 140ms ease;
  }
  .bz-home-archive-button::after {
    content: '→';
    transition: transform 160ms ease;
  }
  .bz-home-archive-button:hover {
    background: var(--claret-deep);
    color: var(--paper);
    transform: translateY(-1px);
  }
  .bz-home-archive-button:hover::after { transform: translateX(3px); }

  .bz-home-archive-cta {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-4);
    background: linear-gradient(180deg, var(--paper-soft), var(--paper-wheat));
    border-top: 3px solid var(--claret);
    box-shadow: var(--shadow-card);
    margin-top: var(--space-7);
    padding: var(--space-5);
  }
  .bz-home-archive-cta__meta {
    color: var(--caption-gray);
    font-size: var(--fs-base);
    line-height: 1.35;
  }
</style>
