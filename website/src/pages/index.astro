---
const base = import.meta.env.BASE_URL;
const target = `${base}en/`;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta http-equiv="refresh" content={`0; url=${target}`} />
    <link rel="canonical" href={target} />
    <title>Redirecting…</title>
  </head>
  <body>
    <p><a href={target}>Continue to English site</a></p>
  </body>
</html>
