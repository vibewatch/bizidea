---
import '../styles/tokens.css';
interface Props {
  title: string;
  description?: string;
}
const { title, description } = Astro.props as Props;
const base = import.meta.env.BASE_URL;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    {description && <meta name="description" content={description} />}
    <link rel="icon" href={`${base}favicon.svg`} type="image/svg+xml" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Bricolage+Grotesque:opsz,wght@12..96,400;12..96,500;12..96,600;12..96,700&family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500;600&display=swap"
    />
  </head>
  <body>
    <header class="bz-utility">
      <div class="bz-container bz-utility__row">
        <a href={base} class="bz-utility__brand" aria-label="BizIdea home">
          <span class="bz-utility__mark" aria-hidden="true">B</span>
          <span>BizIdea</span>
        </a>
        <span class="bz-utility__tag">Startup Dossiers</span>
      </div>
    </header>
    <main>
      <slot />
    </main>
    <footer class="bz-footer">
      <div class="bz-container bz-footer__row">
        <div class="bz-footer__col">
          <span class="bz-footer__brand">BizIdea</span>
          <span class="bz-footer__tag">AI-generated venture research</span>
        </div>
        <div class="bz-footer__col">
          <span class="bz-footer__head">Sections</span>
          <ul>
            <li><a href={base}>Latest</a></li>
            <li><a href={`${base}#more-dossiers`}>All dossiers</a></li>
          </ul>
        </div>
        <div class="bz-footer__col">
          <span class="bz-footer__head">About</span>
          <ul>
            <li>Triage &rarr; idea &rarr; research &rarr; plan &rarr; model</li>
            <li>Generated end-to-end by specialist agents</li>
          </ul>
        </div>
        <div class="bz-footer__col bz-footer__col--meta">
          <span class="bz-footer__head">Build</span>
          <span class="bz-footer__meta">Copyright &copy; 2026 Yingting Huang</span>
        </div>
      </div>
    </footer>

    <style>
      .bz-utility {
        background:
          linear-gradient(90deg, rgba(153, 15, 61, 0.06), transparent 34%),
          var(--paper);
        color: var(--ink-page);
        border-bottom: var(--rule-hairline);
      }
      .bz-utility__row {
        display: flex;
        align-items: center;
        justify-content: space-between;
        min-height: 60px;
        gap: var(--space-4);
      }
      .bz-utility__brand {
        display: inline-flex;
        align-items: center;
        gap: var(--space-2);
        font-family: var(--font-display);
        font-weight: 700;
        font-size: var(--fs-xl);
        line-height: 1;
        letter-spacing: var(--tracking-display-tight);
        color: var(--ink-page);
        text-decoration: none;
      }
      .bz-utility__brand:hover { color: var(--claret); }
      .bz-utility__mark {
        display: inline-grid;
        place-items: center;
        width: 34px;
        height: 34px;
        background: var(--claret);
        color: var(--paper);
        font-family: var(--font-display);
        font-size: var(--fs-md);
        font-weight: 700;
        line-height: 1;
      }
      .bz-utility__tag {
        font-family: var(--font-sans);
        font-variant-caps: all-small-caps;
        font-weight: 600;
        letter-spacing: var(--tracking-eyebrow);
        font-size: 0.875rem;
        line-height: 1;
        color: var(--claret);
        padding: var(--space-2) var(--space-3);
        background: rgba(153, 15, 61, 0.07);
        border: var(--rule-hairline);
      }

      .bz-footer {
        background: var(--ink-black);
        color: var(--paper);
        margin-top: var(--space-9);
        padding: var(--space-7) 0 var(--space-6);
      }
      .bz-footer__row {
        display: grid;
        grid-template-columns: 1fr;
        gap: var(--space-5);
        font-family: var(--font-sans);
        font-size: var(--fs-sm);
      }
      @media (min-width: 700px) {
        .bz-footer__row { grid-template-columns: 1.5fr 1fr 1.4fr 1fr; gap: var(--space-7); align-items: start; }
      }
      .bz-footer__col { display: flex; flex-direction: column; gap: var(--space-2); min-width: 0; }
      .bz-footer__brand {
        font-family: var(--font-display);
        font-size: var(--fs-lg);
        font-weight: 700;
        letter-spacing: var(--tracking-display-tight);
        color: var(--paper);
      }
      .bz-footer__tag { color: var(--paper); opacity: 0.65; }
      .bz-footer__head {
        font-family: var(--font-sans);
        font-variant-caps: all-small-caps;
        letter-spacing: var(--tracking-eyebrow);
        font-weight: 600;
        font-size: var(--fs-xs);
        color: var(--paper);
        opacity: 0.6;
        margin-bottom: var(--space-1);
      }
      .bz-footer__col ul {
        list-style: none;
        padding: 0;
        margin: 0;
        display: flex;
        flex-direction: column;
        gap: var(--space-2);
      }
      .bz-footer__col a {
        color: var(--paper);
        text-decoration: none;
        opacity: 0.85;
      }
      .bz-footer__col a:hover { opacity: 1; color: var(--paper-wheat); }
      .bz-footer__meta { color: var(--paper); opacity: 0.6; }
    </style>
  </body>
</html>
