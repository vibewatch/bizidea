{
  "name": "bizidea-scripts",
  "private": true,
  "type": "module",
  "scripts": {
    "build:ideas-index": "node scripts/ideas-index.mjs",
    "check:agents": "node scripts/check-agent-frontmatter.mjs",
    "check:triage": "node scripts/check-triage.mjs",
    "check:ideas-index": "node scripts/ideas-index.mjs --strict --check",
    "check:duplicates": "node scripts/check-near-duplicates.mjs",
    "check:ideas": "npm --prefix website run check:ideas",
    "check:zh": "node scripts/check-zh-translation.mjs ideas",
    "check:typecheck": "npm --prefix website run typecheck",
    "check:test": "vitest run",
    "validate:all": "node scripts/validate-all.mjs"
  },
  "dependencies": {
    "js-yaml": "^4.1.0"
  },
  "devDependencies": {
    "vitest": "^4.1.5"
  }
}
